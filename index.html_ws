els.applyAnchors.addEventListener('click', async () => {
  if (!lastProposedAnchors) return;
  const recomputedCount = Object.values(lastProposedAnchors).filter(p => p.recomputed).length;
  if (recomputedCount === 0) return;

  const axes = [];
  if (els.applyAxisTemp.checked) axes.push('temp');
  if (els.applyAxisValue.checked) axes.push('value');
  if (els.applyAxisChroma.checked) axes.push('chroma');
  if (axes.length === 0) {
    alert('Sélectionne au moins un axe à appliquer.');
    return;
  }

  const axesLabel = axes.length === 3
    ? 'les 3 axes'
    : axes.map(a => ({ temp: 'température', value: 'valeur', chroma: 'intensité' }[a])).join(' + ');
  if (!confirm(`Appliquer ${axesLabel} pour ${recomputedCount} saison${recomputedCount > 1 ? 's' : ''} ? Les futures analyses utiliseront ces nouvelles ancres.`)) return;

  await applyCustomAnchors(lastProposedAnchors, axes);
  await renderAnalytics();
});

els.restoreAnchors.addEventListener('click', async () => {
  if (!confirm('Restaurer les ancres théoriques par défaut ?')) return;
  await restoreDefaultAnchors();
  await renderAnalytics();
});

