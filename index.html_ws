let faceLandmarker = null;
let currentSeason = null;
let lastAnalysis = null;

function switchView(name) {
  // Stop camera if leaving camera view
  if (name !== 'camera') stopCamera();
  // Stop live mirror if leaving mirror view
  if (name !== 'mirror' && typeof mirrorState !== 'undefined' && mirrorState.running) stopMirror();
  Object.entries(els.views).forEach(([k, el]) => el.classList.toggle('active', k === name));
  if (name === 'upload' && typeof renderRecentStrip === 'function') renderRecentStrip();
  // Sync des onglets de navigation (header + tab bar)
  const activeTab = (typeof NAV_TAB_OF_VIEW !== 'undefined' && NAV_TAB_OF_VIEW[name]) || null;
  document.querySelectorAll('[data-nav]').forEach(b => b.classList.toggle('active', b.dataset.nav === activeTab));
  const labels = {
    upload: 'étape 01 / 03',
    camera: 'étape 01 / 03',
    analyzing: 'étape 02 / 03',
    result: 'étape 03 / 03',
    history: 'historique',
    compare: 'comparaison',
    drape: 'drapés',
    analytics: 'analyse',
    reco: 'recommandations',
    mirror: 'miroir vivant',
    refine: 'affinage'
  };
  els.step.textContent = labels[name] || '';
}

function showError(msg) {
  els.error.textContent = msg;
  els.error.classList.add('show');
  switchView('upload');
}

function clearError() {
  els.error.classList.remove('show');
}

// === MediaPipe init ===
async function initMediaPipe() {
  if (faceLandmarker) return faceLandmarker;
  els.progress.textContent = 'Chargement du modèle…';
  const vision = await FilesetResolver.forVisionTasks(
    "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm"
  );
  faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
    baseOptions: {
      modelAssetPath: "https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task"
    },
    runningMode: "IMAGE",
    numFaces: 1
  });
  return faceLandmarker;
}

let imageSegmenter = null;

async function initSegmenter() {
  if (imageSegmenter) return imageSegmenter;
  const vision = await FilesetResolver.forVisionTasks(
    "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm"
  );
  imageSegmenter = await ImageSegmenter.createFromOptions(vision, {
    baseOptions: {
      modelAssetPath: "https://storage.googleapis.com/mediapipe-models/image_segmenter/selfie_multiclass_256x256/float32/latest/selfie_multiclass_256x256.tflite"
    },
    runningMode: "IMAGE",
    outputCategoryMask: true,
    outputConfidenceMasks: false
  });
  return imageSegmenter;
}

// Selfie multiclass categories:
// 0 = background, 1 = hair, 2 = body-skin, 3 = face-skin, 4 = clothes, 5 = others
const SEG_HAIR = 1;
const SEG_FACE_SKIN = 3;

function sampleHairFromMask(imageData, mask) {
  const W = imageData.width, H = imageData.height;
  if (mask.length !== W * H) return null;

  // Find all hair pixel indices
  const hairIdx = [];
  for (let i = 0; i < mask.length; i++) {
    if (mask[i] === SEG_HAIR) hairIdx.push(i);
  }
  if (hairIdx.length < 200) return null;

  // Subsample to ~600 pixels for performance
  const target = 600;
  const step = Math.max(1, Math.floor(hairIdx.length / target));
  const samples = [];
  for (let j = 0; j < hairIdx.length; j += step) {
    const p = hairIdx[j] * 4;
    samples.push({
      r: imageData.data[p],
      g: imageData.data[p + 1],
      b: imageData.data[p + 2]
    });
  }

  // Convert to Lab and filter outliers (wider range than skin, hair can be very dark or very light)
  const labs = samples.map(s => rgbToLab(s.r, s.g, s.b))
                      .filter(l => l.L > 5 && l.L < 96);
  if (labs.length < 30) return null;

  return {
    L: median(labs.map(l => l.L)),
    a: median(labs.map(l => l.a)),
    b: median(labs.map(l => l.b)),
    pixelCount: hairIdx.length
  };
}

// Sample face-skin pixels from segmentation mask, binned by quadrant
// Returns median Lab + inter-quadrant variance (same scale as 3-zone heuristic)
function sampleSkinFromMaskByQuadrant(imageData, mask, landmarks) {
  const W = imageData.width, H = imageData.height;
  if (mask.length !== W * H) return null;

  // Face bounding box from landmarks
  let minX = 1, maxX = 0, minY = 1, maxY = 0;
  for (const lm of landmarks) {
    if (lm.x < minX) minX = lm.x;
    if (lm.x > maxX) maxX = lm.x;
    if (lm.y < minY) minY = lm.y;
    if (lm.y > maxY) maxY = lm.y;
  }
  const midX = (minX + maxX) / 2 * W;
  const midY = (minY + maxY) / 2 * H;

  // Quadrant buckets: 0=TL, 1=TR, 2=BL, 3=BR
  const quad = [[], [], [], []];
  let total = 0;
  for (let i = 0; i < mask.length; i++) {
    if (mask[i] !== SEG_FACE_SKIN) continue;
    const x = i % W, y = (i / W) | 0;
    const q = (x < midX ? 0 : 1) + (y < midY ? 0 : 2);
    quad[q].push(i);
    total++;
  }
  if (total < 500) return null;

  // Compute median Lab per quadrant (subsampled)
  const quadLabs = quad.map(idxs => {
    if (idxs.length < 60) return null;
    const step = Math.max(1, Math.floor(idxs.length / 250));
    const samples = [];
    for (let j = 0; j < idxs.length; j += step) {
      const p = idxs[j] * 4;
      samples.push({ r: imageData.data[p], g: imageData.data[p + 1], b: imageData.data[p + 2] });
    }
    const labs = samples.map(s => rgbToLab(s.r, s.g, s.b))
                        .filter(l => l.L > 12 && l.L < 92);
    if (labs.length < 12) return null;
    return {
      L: median(labs.map(l => l.L)),
      a: median(labs.map(l => l.a)),
      b: median(labs.map(l => l.b))
    };
  });

  const valid = quadLabs.filter(q => q !== null);
  if (valid.length === 0) return null;

  // Global skin = median of valid quadrants (robust to outlier quadrant)
  const skin = {
    L: median(valid.map(q => q.L)),
    a: median(valid.map(q => q.a)),
    b: median(valid.map(q => q.b))
  };

  // Inter-quadrant variance (stddev of L), comparable to 3-zone heuristic scale
  let variance = 0;
  if (valid.length > 1) {
    const meanL = valid.reduce((s, q) => s + q.L, 0) / valid.length;
    variance = Math.sqrt(
      valid.reduce((s, q) => s + (q.L - meanL) ** 2, 0) / valid.length
    );
  }

  return {
    skin, variance,
    quadrantsCount: valid.length,
    pixelCount: total
  };
}

// === Image loading with EXIF rotation respected ===
function loadImage(file) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.onload = () => resolve(img);
    img.onerror = () => reject(new Error('Impossible de lire le fichier image'));
    img.src = URL.createObjectURL(file);
  });
}

// === Main analysis pipeline ===
async function analyze(file) {
  try {
    clearError();
    switchView('analyzing');

    els.progress.textContent = 'Lecture de l\'image…';
    const img = await loadImage(file);

    // Resize to a sensible working resolution
    const maxDim = 1200;
    const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
    const W = Math.round(img.width * scale);
    const H = Math.round(img.height * scale);

    const canvas = els.preview;
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d', { willReadFrequently: true });
    ctx.drawImage(img, 0, 0, W, H);

    els.progress.textContent = 'Initialisation du modèle…';
    const landmarker = await initMediaPipe();

    els.progress.textContent = 'Détection du visage…';
    const result = landmarker.detect(canvas);

    if (!result.faceLandmarks || result.faceLandmarks.length === 0) {
      throw new Error('Aucun visage détecté. Essaie une photo plus claire, de face.');
    }

    const landmarks = result.faceLandmarks[0];
    if (landmarks.length < 468) {
      throw new Error('Détection partielle. Essaie une autre photo.');
    }

    els.progress.textContent = 'Échantillonnage chromatique…';
    await new Promise(r => setTimeout(r, 200));

    let imageData = ctx.getImageData(0, 0, W, H);

    // === Preflight checks ===
    const preflight = preflightCheck(imageData, landmarks, W, H);
    const preflightIssues = preflight.issues;
    const exposureInfo = preflight.exposure;
    const criticalIssues = preflightIssues.filter(i => i.severity === 'critical');
    if (criticalIssues.length > 0) {
      throw new Error('Photo non analysable : ' + criticalIssues.map(i => i.msg).join(' · ') + '.');
    }

    // === White balance calibration via sclera ===
    els.progress.textContent = 'Calibration colorimétrique…';
    const whiteRef = estimateWhiteReference(imageData, landmarks);
    const calibration = { applied: false, scleraCount: 0, gains: null, whiteRef: null };
    if (whiteRef) {
      const corrected = applyWhiteBalance(imageData, whiteRef);
      imageData = corrected.imageData;
      // Reflect corrected image on the preview canvas
      ctx.putImageData(imageData, 0, 0);
      calibration.applied = true;
      calibration.scleraCount = whiteRef.count;
      calibration.gains = corrected.gains;
      calibration.whiteRef = { r: whiteRef.r, g: whiteRef.g, b: whiteRef.b };
    }

    await new Promise(r => setTimeout(r, 150));

    // === Hair + Skin segmentation ===
    els.progress.textContent = 'Segmentation visage/cheveux…';
    let segMask = null;
    try {
      const segmenter = await initSegmenter();
      const segResult = segmenter.segment(canvas);
      if (segResult && segResult.categoryMask) {
        segMask = segResult.categoryMask.getAsUint8Array().slice(); // copy before close
        segResult.close();
      }
    } catch (e) {
      console.warn('Segmentation failed, falling back to heuristic sampling:', e);
    }

    await new Promise(r => setTimeout(r, 100));
    const features = extractFeatures(imageData, landmarks, segMask);

    // Tonemap detection + correction (uses sclera-calibrated image + hair mask)
    const tonemap = detectTonemap(imageData, segMask);
    applyTonemapCorrection(features, tonemap);

    // Draw sampling points overlay
    drawSamplingOverlay(W, H, features.samplePoints, features.hairSource, features.skinSource);

    els.progress.textContent = 'Classification…';
    await new Promise(r => setTimeout(r, 350));

    const classification = classify(features);
    const confidence = computeConfidence(features, calibration, preflightIssues, classification.ranked);

    // Save data for drape view + future validation
    lastAnalysis = {
      imageData: imageData,
      segMask: segMask,
      landmarks: landmarks,
      features: features,
      classification: classification,
      confidence: confidence,
      calibration: calibration,
      exposure: exposureInfo,
      W: W, H: H,
      savedId: null,    // populated after IDB save
      userPick: null    // populated when user validates a season
    };

    showResult(features, classification, confidence, calibration, null, exposureInfo);
    saveToHistory(features, classification, confidence, calibration, exposureInfo);
  } catch (e) {
    console.error(e);
    showError(e.message || 'Une erreur est survenue durant l\'analyse');
  }
}

function drawSamplingOverlay(W, H, p, hairSource, skinSource) {
  els.overlay.setAttribute('viewBox', `0 0 ${W} ${H}`);
  els.overlay.innerHTML = '';
  const points = [
    { ...p.iR, r: p.rIris, label: '' },
    { ...p.iL, r: p.rIris, label: '' }
  ];
  // Only show cheek/forehead points if heuristic was used for skin
  if (skinSource !== 'mask') {
    points.push({ ...p.cR, r: p.r, label: 'C' });
    points.push({ ...p.cL, r: p.r, label: 'C' });
    points.push({ ...p.fH, r: p.r, label: 'F' });
  }
  // Only show heuristic hair point if mask-based wasn't used
  if (hairSource !== 'mask') {
    points.push({ ...p.hP, r: p.r, label: 'H' });
  }
  for (const pt of points) {
    const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    c.setAttribute('cx', pt.x);
    c.setAttribute('cy', pt.y);
    c.setAttribute('r', pt.r);
    c.setAttribute('fill', 'none');
    c.setAttribute('stroke', '#6B2737');
    c.setAttribute('stroke-width', '2');
    c.setAttribute('opacity', '0.85');
    els.overlay.appendChild(c);
  }
}

// SVG scatter of the 12 season anchors in temp × value space.
// Dot radius encodes chroma (muted small → clear large). User position drawn
// as an accent ring. Uses activeAnchors so recalibrations are reflected.
function renderSeasonMap(features, winnerSeason) {
  const container = document.getElementById('season-map');
  if (!container) return;

  const VW = 320, VH = 210;
  const PAD = { l: 30, r: 14, t: 14, b: 26 };
  const plotW = VW - PAD.l - PAD.r;
  const plotH = VH - PAD.t - PAD.b;

  // Same normalization as rankSeasons
  const nx = v => PAD.l + ((v + 1.2) / 2.4) * plotW;          // temp: -1.2..1.2 → x
  const ny = v => PAD.t + ((1.2 - v) / 2.4) * plotH;          // value: 1.2..-1.2 → y (light on top)
  const cr = c => 3.2 + ((c + 1.2) / 2.4) * 3.8;              // chroma → radius 3.2..7

  const userT = Math.max(-1.2, Math.min(1.2, (features.warmth - 15) / 20));
  const userV = Math.max(-1.2, Math.min(1.2, (features.value - 55) / 25));
  const userC = Math.max(-1.2, Math.min(1.2, (features.skinChroma - 15) / 15));

  let dots = '';
  for (const [season, a] of Object.entries(activeAnchors)) {
    const data = SEASONS[season];
    const hex = data?.palette?.[0]?.[1] || '#999';
    const x = nx(a.temp), y = ny(a.value), r = cr(a.chroma);
    const isWinner = season === winnerSeason;
    dots += `
      <circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="${r.toFixed(1)}"
        fill="${hex}" stroke="${isWinner ? 'var(--accent)' : 'var(--line)'}"
        stroke-width="${isWinner ? 2 : 0.8}" opacity="${isWinner ? 1 : 0.75}">
        <title>${data ? data.rest + ' ' + data.em : season} · T ${a.temp} / V ${a.value} / C ${a.chroma}</title>
      </circle>
      <text class="map-season-label${isWinner ? ' winner' : ''}"
        x="${x.toFixed(1)}" y="${(y + r + 7).toFixed(1)}" text-anchor="middle">${SEASON_ABBR[season] || ''}</text>`;
  }

  const ux = nx(userT), uy = ny(userV), ur = cr(userC);
  const user = `
    <circle cx="${ux.toFixed(1)}" cy="${uy.toFixed(1)}" r="${(ur + 3).toFixed(1)}"
      fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-dasharray="3 2">
      <title>Toi · T ${userT.toFixed(2)} / V ${userV.toFixed(2)} / C ${userC.toFixed(2)}</title>
    </circle>
    <circle cx="${ux.toFixed(1)}" cy="${uy.toFixed(1)}" r="2.2" fill="var(--accent)"/>`;

  container.innerHTML = `
    <svg viewBox="0 0 ${VW} ${VH}" xmlns="http://www.w3.org/2000/svg" role="img"
      aria-label="Carte des saisons : position mesurée parmi les douze ancres">
      <line x1="${PAD.l}" y1="${ny(0)}" x2="${VW - PAD.r}" y2="${ny(0)}" stroke="var(--line)" stroke-width="0.6" stroke-dasharray="2 3"/>
      <line x1="${nx(0)}" y1="${PAD.t}" x2="${nx(0)}" y2="${VH - PAD.b}" stroke="var(--line)" stroke-width="0.6" stroke-dasharray="2 3"/>
      <text class="map-axis-label" x="${PAD.l}" y="${VH - 8}">froid</text>
      <text class="map-axis-label" x="${VW - PAD.r}" y="${VH - 8}" text-anchor="end">chaud</text>
      <text class="map-axis-label" x="${PAD.l - 4}" y="${PAD.t + 6}" text-anchor="end" transform="rotate(-90 ${PAD.l - 4} ${PAD.t + 6})">clair</text>
      <text class="map-axis-label" x="${PAD.l - 4}" y="${VH - PAD.b}" text-anchor="end" transform="rotate(-90 ${PAD.l - 4} ${VH - PAD.b})">foncé</text>
      ${dots}
      ${user}
    </svg>`;
}

function showResult(features, classif, confidence, calibration, algoOriginalSeason = null, exposure = null) {
  const data = SEASONS[classif.season];
  if (!data) {
    showError('Classification impossible. Réessaie avec une autre photo.');
    return;
  }
  currentSeason = classif.season;

  // Name
  els.seasonName.innerHTML = `${data.rest} <em>${data.em}</em>`;

  // Divergence note (visible only if user pick differs from algo's original)
  const meta = els.seasonMeta;
  if (meta) {
    if (algoOriginalSeason && algoOriginalSeason !== classif.season) {
      const algoData = SEASONS[algoOriginalSeason];
      const algoLabel = algoData ? `${algoData.rest} ${algoData.em}` : algoOriginalSeason;
      meta.innerHTML = `<span class="meta-tag validated">✓ Choix validé</span> <span class="meta-tag muted">algo : ${algoLabel}</span>`;
      meta.style.display = '';
    } else if (algoOriginalSeason && algoOriginalSeason === classif.season) {
      meta.innerHTML = `<span class="meta-tag validated">✓ Choix validé</span>`;
      meta.style.display = '';
    } else {
      meta.innerHTML = '';
      meta.style.display = 'none';
    }
  }

  els.seasonDesc.textContent = data.desc;

  // Confidence badge
  els.confidenceScore.textContent = `${confidence.score}%`;
  els.confidenceLabel.textContent = `Confiance ${confidence.label}`;
  els.confidenceBadge.className = 'confidence-badge ' + (
    confidence.score >= 85 ? 'high' :
    confidence.score >= 70 ? 'good' :
    confidence.score >= 55 ? 'medium' : 'low'
  );

  // Penalties / notes
  if (confidence.penalties.length > 0) {
    els.confidenceNotes.innerHTML =
      '<div class="notes-label">Limites identifiées</div>' +
      '<ul>' + confidence.penalties.map(p => `<li>${p}</li>`).join('') + '</ul>';
    els.confidenceNotes.style.display = 'block';
  } else {
    els.confidenceNotes.style.display = 'none';
  }

  // Axes
  setAxis(els.cTemp, els.vTemp, classif.tempAxis, features.warmth > 12 ? 'Chaud' : 'Froid', classif.axisConf?.temp);
  setAxis(els.cVal, els.vVal, classif.valueAxis, features.value > 58 ? 'Clair' : features.value < 42 ? 'Foncé' : 'Médian', classif.axisConf?.value);
  setAxis(els.cChroma, els.vChroma, classif.chromaAxis, features.skinChroma > 18 ? 'Vif' : features.skinChroma < 12 ? 'Doux' : 'Médian', classif.axisConf?.chroma);

  // Alternative seasons — show top 2-3 within 15 points of the winner
  if (classif.ranked && classif.ranked.length >= 2 && els.resultAlternatives) {
    const top = classif.ranked[0];
    const alternatives = classif.ranked
      .slice(1, 4)
      .filter(r => (top.score - r.score) <= 15);
    if (alternatives.length > 0) {
      els.altList.innerHTML = alternatives.map(alt => {
        const altData = SEASONS[alt.season];
        const delta = top.score - alt.score;
        const name = altData ? `${altData.rest} ${altData.em}` : alt.season;
        return `<span class="alt-item"><span class="alt-name">${name}</span><span class="alt-delta">−${delta}</span></span>`;
      }).join('');
      els.resultAlternatives.hidden = false;
    } else {
      els.resultAlternatives.hidden = true;
    }
  } else if (els.resultAlternatives) {
    els.resultAlternatives.hidden = true;
  }

  // Thème saisonnier D'ABORD (isolé : un échec de la carte ne doit plus le bloquer)
  setSeasonTheme(classif.season);
  dbSetConfig('accent_season', classif.season);

  // Season space map
  try { renderSeasonMap(features, classif.season); }
  catch (e) { console.warn('seasonMap:', e); }

  // Data table — grouped by signal source
  const rows = [
    ['— Score', ''],
    ['Confiance globale', `${confidence.score}%`],
    ['Calibration WB', calibration.applied ? `Oui (n=${calibration.scleraCount})` : 'Non']
  ];
  if (exposure && exposure.score !== null) {
    const statusFr = {
      'good': 'optimale',
      'suboptimal-dark': 'légèrement sombre',
      'suboptimal-bright': 'légèrement claire',
      'underexposed': 'sous-exposée',
      'overexposed': 'sur-exposée',
      'critically-dark': 'critique (sombre)',
      'critically-bright': 'critique (cramée)',
      'no-skin': 'peau non détectée'
    };
    rows.push(['Exposition visage', `${exposure.score}% · ${statusFr[exposure.status] || exposure.status} (L*=${exposure.faceL?.toFixed(0) ?? '—'})`]);
  }
  rows.push(['— Peau', '']);
  rows.push(['Source', features.skinSource === 'mask' ? `Masque (n=${features.skinPixelCount})` : `Heuristique (${features.skinZonesCount}/3 zones)`]);
  if (features.skin.L_raw !== undefined) {
    rows.push(['L* (corrigé / brut)', `${features.skin.L.toFixed(1)} / ${features.skin.L_raw.toFixed(1)}`]);
    rows.push(['a* / b*', `${features.skin.a.toFixed(1)} / ${features.skin.b.toFixed(1)}`]);
  } else {
    rows.push(['L* / a* / b*', `${features.skin.L.toFixed(1)} / ${features.skin.a.toFixed(1)} / ${features.skin.b.toFixed(1)}`]);
  }
  rows.push(['ITA', `${features.ita.toFixed(1)}°`]);
  rows.push(['C* (chroma)', features.skinChroma.toFixed(1)]);
  rows.push(['Hue', `${features.skinHue.toFixed(0)}°`]);
  rows.push(['σ inter-zones', features.skinVariance.toFixed(1)]);
  if (features.hair) {
    rows.push(['— Cheveux', '']);
    rows.push(['Source', features.hairSource === 'mask' ? `Masque (n=${features.hairPixelCount})` : 'Heuristique']);
    if (features.hair.L_raw !== undefined) {
      rows.push(['L* (corrigé / brut)', `${features.hair.L.toFixed(1)} / ${features.hair.L_raw.toFixed(1)}`]);
      rows.push(['a* / b*', `${features.hair.a.toFixed(1)} / ${features.hair.b.toFixed(1)}`]);
    } else {
      rows.push(['L* / a* / b*', `${features.hair.L.toFixed(1)} / ${features.hair.a.toFixed(1)} / ${features.hair.b.toFixed(1)}`]);
    }
    rows.push(['Contraste peau↔cheveux', features.contrast.toFixed(1)]);
  }
  if (features.iris) {
    rows.push(['— Iris', '']);
    if (features.iris.L_raw !== undefined) {
      rows.push(['L* (corrigé / brut)', `${features.iris.L.toFixed(1)} / ${features.iris.L_raw.toFixed(1)}`]);
      rows.push(['a* / b*', `${features.iris.a.toFixed(1)} / ${features.iris.b.toFixed(1)}`]);
    } else {
      rows.push(['L* / a* / b*', `${features.iris.L.toFixed(1)} / ${features.iris.a.toFixed(1)} / ${features.iris.b.toFixed(1)}`]);
    }
    rows.push(['Couleur approchée', labApproxToHex(features.iris)]);
  }
  if (features.tonemap?.detected) {
    rows.push(['— Tonemap', '']);
    rows.push(['Levée d\'ombres détectée', `+${features.tonemap.shadowLift.toFixed(1)} L*`]);
    rows.push(['Hair P5 mesuré → cible', `${features.tonemap.hairP5.toFixed(1)} → ${features.tonemap.expectedHairP5}`]);
    rows.push(['Force de correction', '50% (blend modéré)']);
  }
  rows.push(['— Fusion multi-signal', '']);
  rows.push(['Warmth fusionnée', features.warmth.toFixed(1)]);
  rows.push(['Value fusionnée', features.value.toFixed(1)]);
  if (classif.axisConf) {
    rows.push(['Confiance température', `${classif.axisConf.temp}%`]);
    rows.push(['Confiance valeur', `${classif.axisConf.value}%`]);
    rows.push(['Confiance intensité', `${classif.axisConf.chroma}%`]);
  }
  if (classif.ranked && classif.ranked.length >= 2) {
    rows.push(['Marge top-1 / top-2', `Δ${classif.ranked[0].score - classif.ranked[1].score}`]);
  }
  els.dataTable.innerHTML = rows.map(([k, v]) => {
    if (k.startsWith('— ')) {
      return `<div class="data-row data-section">${k.slice(2)}</div>`;
    }
    return `<div class="data-row"><span>${k}</span><span>${v}</span></div>`;
  }).join('');

  // Palette
  els.paletteSwatches.innerHTML = data.palette.map(([name, hex], i) => swatchHTML(name, hex, i)).join('');
  els.paletteCount.textContent = `${data.palette.length} couleurs`;

  // Avoid
  els.avoidSwatches.innerHTML = data.avoid.map(([name, hex], i) => swatchHTML(name, hex, i)).join('');

  // Drape button visibility — only available with fresh analysis data
  els.openDrape.style.display = lastAnalysis ? '' : 'none';

  switchView('result');
}

function setAxis(cursor, valEl, percent, label, conf) {
  cursor.style.left = `${percent}%`;
  if (typeof conf === 'number') {
    const cls = conf >= 75 ? 'high' : conf >= 55 ? 'mid' : 'low';
    valEl.innerHTML = `${label} <span class="axis-conf ${cls}">conf ${conf}%</span>`;
  } else {
    valEl.textContent = label;
  }
}

function swatchHTML(name, hex, i = 0) {
  return `
    <div class="swatch" title="${name} — ${hex}" style="--i:${i}">
      <div class="swatch-color" style="background:${hex}"></div>
      <div class="swatch-label">${name}</div>
      <div class="swatch-hex">${hex.toUpperCase()}</div>
    </div>
  `;
}

// Approximate Lab → hex for display (reverse not done precisely; just for indication)
function labToRgb(L, a, b) {
  // Lab → XYZ (D65)
  const fy = (L + 16) / 116;
  const fx = a / 500 + fy;
  const fz = fy - b / 200;
  const finv = (t) => t > 0.206893 ? t * t * t : (t - 16/116) / 7.787;
  const X = 0.95047 * finv(fx);
  const Y = 1.0     * finv(fy);
  const Z = 1.08883 * finv(fz);

  // XYZ → linear sRGB
  let r =  3.2404542 * X - 1.5371385 * Y - 0.4985314 * Z;
  let g = -0.9692660 * X + 1.8760108 * Y + 0.0415560 * Z;
  let bb = 0.0556434 * X - 0.2040259 * Y + 1.0572252 * Z;

  // Linear → sRGB
  const toSrgb = (c) => {
    c = c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(c, 1/2.4) - 0.055;
    return Math.max(0, Math.min(255, Math.round(c * 255)));
  };
  return { r: toSrgb(r), g: toSrgb(g), b: toSrgb(bb) };
}

function labApproxToHex(lab) {
  const rgb = labToRgb(lab.L, lab.a, lab.b);
  return '#' + [rgb.r, rgb.g, rgb.b].map(n => n.toString(16).padStart(2, '0')).join('').toUpperCase();
}

function hexToRgb(hex) {
  const h = hex.replace('#', '');
  return {
    r: parseInt(h.slice(0, 2), 16),
    g: parseInt(h.slice(2, 4), 16),
    b: parseInt(h.slice(4, 6), 16)
  };
}

// ============================================================
// ANALYTICS — confusion matrix and anchor recalibration
// ============================================================

function buildConfusionMatrix(entries) {
  const keys = Object.keys(SEASON_ANCHORS);
  const matrix = {};
  for (const a of keys) {
    matrix[a] = {};
    for (const u of keys) matrix[a][u] = 0;
  }
  let totalValidated = 0;
  let diagonalSum = 0;
  for (const e of entries) {
    if (!e.userPick) continue;
    const algoS = e.classification?.season || e.season;
    const userS = e.userPick.season;
    if (matrix[algoS] && matrix[algoS][userS] !== undefined) {
      matrix[algoS][userS]++;
      totalValidated++;
      if (algoS === userS) diagonalSum++;
    }
  }
  return {
    matrix,
    totalValidated,
    correctCount: diagonalSum,
    accuracy: totalValidated > 0 ? diagonalSum / totalValidated : null
  };
}

function recomputeAnchors(entries, minSamples = 3) {
  const proposed = {};
  for (const season of Object.keys(SEASON_ANCHORS)) {
    const validated = entries.filter(e => e.userPick?.season === season);
    const count = validated.length;

    if (count < minSamples) {
      proposed[season] = {
        ...SEASON_ANCHORS[season],
        samples: count,
        recomputed: false
      };
      continue;
    }

    const warmths = validated.map(e => e.features.warmth);
    const values  = validated.map(e => e.features.value);
    const chromas = validated.map(e => e.features.skinChroma);

    const mW = median(warmths);
    const mV = median(values);
    const mC = median(chromas);

    // Same normalization as rankSeasons input space
    const temp   = Math.max(-1.2, Math.min(1.2, (mW - 15) / 20));
    const value  = Math.max(-1.2, Math.min(1.2, (mV - 55) / 25));
    const chroma = Math.max(-1.2, Math.min(1.2, (mC - 15) / 15));

    proposed[season] = {
      temp:   Math.round(temp   * 100) / 100,
      value:  Math.round(value  * 100) / 100,
      chroma: Math.round(chroma * 100) / 100,
      samples: count,
      recomputed: true
    };
  }
  return proposed;
}

function buildActiveAnchorsFromProposed(proposed, axes = ['temp', 'value', 'chroma']) {
  const out = {};
  for (const season of Object.keys(SEASON_ANCHORS)) {
    // Start from current activeAnchors so unchecked axes preserve their existing value
    // (whether default or previously custom)
    const base = activeAnchors[season] || SEASON_ANCHORS[season];
    out[season] = { ...base };
    if (proposed[season]?.recomputed) {
      for (const axis of axes) {
        out[season][axis] = proposed[season][axis];
      }
    }
  }
  return out;
}

async function applyCustomAnchors(proposed, axes = ['temp', 'value', 'chroma']) {
  const active = buildActiveAnchorsFromProposed(proposed, axes);
  activeAnchors = active;
  anchorsAreCustom = true;
  await dbSetConfig('anchors', active);
}

async function restoreDefaultAnchors() {
  activeAnchors = JSON.parse(JSON.stringify(SEASON_ANCHORS));
  anchorsAreCustom = false;
  await dbDeleteConfig('anchors');
}

async function loadCustomAnchorsAtStartup() {
  const custom = await dbGetConfig('anchors');
  if (custom && typeof custom === 'object') {
    activeAnchors = custom;
    anchorsAreCustom = true;
  }
}

// ============================================================
// DRAPE TEST — virtual fabric simulation + harmony ranking
// ============================================================

// Theoretical anchor of each season on 3 normalized axes [-1, 1]
// temp: -1 (cool) … +1 (warm)
// value: -1 (dark) … +1 (light)
// chroma: -1 (muted) … +1 (clear)
const SEASON_ANCHORS = {
  'light-spring':  { temp:  0.8, value:  1.0, chroma:  0.0 },
  'true-spring':   { temp:  1.0, value:  0.1, chroma:  0.7 },
  'bright-spring': { temp:  0.5, value:  0.2, chroma:  1.0 },
  'light-summer':  { temp: -0.7, value:  1.0, chroma:  0.0 },
  'true-summer':   { temp: -0.9, value:  0.0, chroma:  0.0 },
  'soft-summer':   { temp: -0.5, value: -0.2, chroma: -1.0 },
  'soft-autumn':   { temp:  0.5, value: -0.2, chroma: -1.0 },
  'true-autumn':   { temp:  1.0, value: -0.3, chroma:  0.3 },
  'deep-autumn':   { temp:  0.8, value: -1.0, chroma:  0.0 },
  'bright-winter': { temp: -0.5, value:  0.2, chroma:  1.0 },
  'true-winter':   { temp: -1.0, value: -0.2, chroma:  0.5 },
  'deep-winter':   { temp: -0.8, value: -1.0, chroma:  0.0 }
};

// Runtime anchors — may be overridden by user-recalibrated values from IDB
let activeAnchors = JSON.parse(JSON.stringify(SEASON_ANCHORS));
let anchorsAreCustom = false;

// Compact season labels for confusion matrix headers
const SEASON_ABBR = {
  'light-spring':  'LSp', 'true-spring':  'TSp', 'bright-spring': 'BSp',
  'light-summer':  'LSu', 'true-summer':  'TSu', 'soft-summer':   'SSu',
  'soft-autumn':   'SAu', 'true-autumn':  'TAu', 'deep-autumn':   'DAu',
  'bright-winter': 'BWi', 'true-winter':  'TWi', 'deep-winter':   'DWi'
};

function rankSeasons(features) {
  // Normalize user features to roughly [-1, 1]
  const userT = Math.max(-1.2, Math.min(1.2, (features.warmth - 15) / 20));
  const userV = Math.max(-1.2, Math.min(1.2, (features.value - 55) / 25));
  const userC = Math.max(-1.2, Math.min(1.2, (features.skinChroma - 15) / 15));

  const scored = Object.entries(activeAnchors).map(([season, anchor]) => {
    const dT = userT - anchor.temp;
    const dV = userV - anchor.value;
    const dC = userC - anchor.chroma;
    // Weighted Euclidean: temperature is the most important axis colorimetrically
    const dist = Math.sqrt(1.5 * dT * dT + 1.0 * dV * dV + 0.8 * dC * dC);
    return { season, distance: dist, score: Math.round(100 * Math.exp(-0.5 * dist)) };
  });

  scored.sort((a, b) => a.distance - b.distance);
  return scored;
}

// Composite a drape color over an image, replacing background/clothes/others
// while preserving hair, face-skin, and body-skin (via segmentation mask).
// Texture-preserving: the drape's L* becomes the new baseline, but each pixel
// keeps its variation relative to the area's mean L*.
// This fixes the case where neutral drapes (black, white) would otherwise
// inherit the background's lightness and never actually appear black or white.
function compositeWithDrape(imageData, segMask, landmarks, drapeRgb) {
  const W = imageData.width, H = imageData.height;
  const drapeLab = rgbToLab(drapeRgb.r, drapeRgb.g, drapeRgb.b);
  const out = new Uint8ClampedArray(imageData.data);

  // Collect target pixel indices (background/clothes/others if mask, or below chin)
  const targets = [];
  if (segMask && segMask.length === W * H) {
    for (let i = 0; i < segMask.length; i++) {
      const cat = segMask[i];
      if (cat !== 1 && cat !== 2 && cat !== 3) targets.push(i);
    }
  } else if (landmarks) {
    let maxFaceY = 0;
    for (const lm of landmarks) {
      if (lm.y > maxFaceY) maxFaceY = lm.y;
    }
    const startY = Math.floor(maxFaceY * H + 5);
    for (let y = startY; y < H; y++) {
      for (let x = 0; x < W; x++) targets.push(y * W + x);
    }
  }
  if (targets.length === 0) return new ImageData(out, W, H);

  // First pass: mean L* of the area being recolored
  let sumL = 0;
  for (const idx of targets) {
    const p = idx * 4;
    const lab = rgbToLab(out[p], out[p + 1], out[p + 2]);
    sumL += lab.L;
  }
  const meanL = sumL / targets.length;

  // Second pass: drape L* is the new baseline; per-pixel deltas preserved (×0.7)
  const textureWeight = 0.7;
  for (const idx of targets) {
    const p = idx * 4;
    const lab = rgbToLab(out[p], out[p + 1], out[p + 2]);
    const deltaL = lab.L - meanL;
    const newL = Math.max(0, Math.min(100, drapeLab.L + deltaL * textureWeight));
    const rgb = labToRgb(newL, drapeLab.a, drapeLab.b);
    out[p]     = rgb.r;
    out[p + 1] = rgb.g;
    out[p + 2] = rgb.b;
  }

  return new ImageData(out, W, H);
}

// ============================================================
// CAMERA — live capture with framing guide
// ============================================================

let videoLandmarker = null;
let videoStream = null;
let detectLoopRunning = false;
let stableFrames = 0;
let lastDetectAt = 0;
let countdownInterval = null;

async function initVideoLandmarker() {
  if (videoLandmarker) return videoLandmarker;
  const vision = await FilesetResolver.forVisionTasks(
    "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm"
  );
  videoLandmarker = await FaceLandmarker.createFromOptions(vision, {
    baseOptions: {
      modelAssetPath: "https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task"
    },
    runningMode: "VIDEO",
    numFaces: 1
  });
  return videoLandmarker;
}

function setCameraStatus(text) {
  if (els.cameraStatus) els.cameraStatus.textContent = text;
}

// Facing partagé capture + miroir : 'user' (selfie) | 'environment' (arrière).
// Persisté en config IDB ; { ideal } et non { exact } pour que les appareils
// mono-caméra (desktop) ne rejettent pas la contrainte.
let cameraFacing = 'user';
dbGetConfig('camera_facing').then(v => { if (v === 'environment' || v === 'user') cameraFacing = v; });

function applyPreviewMirror() {
  document.getElementById('camera-frame')?.classList.toggle('rear', cameraFacing === 'environment');
}

async function startCamera() {
  try {
    clearError();
    switchView('camera');
    setCameraStatus('Demande d\'accès caméra…');
    applyPreviewMirror();

    videoStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: { ideal: cameraFacing }, width: { ideal: 1280 }, height: { ideal: 960 } },
      audio: false
    });
    els.video.srcObject = videoStream;

    await new Promise((resolve) => {
      if (els.video.readyState >= 2) return resolve();
      els.video.onloadedmetadata = () => resolve();
    });
    await els.video.play().catch(() => {}); // iOS quirk

    setCameraStatus('Chargement du modèle…');
    await initVideoLandmarker();

    setCameraStatus('Place ton visage dans le cadre');
    detectLoopRunning = true;
    stableFrames = 0;
    lastDetectAt = 0;
    requestAnimationFrame(detectLoop);
  } catch (e) {
    console.error(e);
    stopCamera();
    let msg = 'Impossible d\'accéder à la caméra.';
    if (e.name === 'NotAllowedError' || e.name === 'PermissionDeniedError') {
      msg = 'Autorisation caméra refusée. Active-la dans les réglages du navigateur.';
    } else if (e.name === 'NotFoundError' || e.name === 'DevicesNotFoundError') {
      msg = 'Aucune caméra détectée sur cet appareil.';
    } else if (e.name === 'NotReadableError') {
      msg = 'La caméra est déjà utilisée par une autre application.';
    }
    showError(msg);
  }
}

function stopCamera() {
  detectLoopRunning = false;
  cancelCountdown();
  if (videoStream) {
    videoStream.getTracks().forEach(t => t.stop());
    videoStream = null;
  }
  if (els.video) els.video.srcObject = null;
  if (els.cameraFrame) els.cameraFrame.classList.remove('ready');
}

function detectLoop() {
  if (!detectLoopRunning) return;
  const now = performance.now();
  // Throttle to ~12 fps to keep CPU happy
  if (now - lastDetectAt > 80 && els.video.readyState >= 2 && videoLandmarker) {
    lastDetectAt = now;
    let quality;
    try {
      const result = videoLandmarker.detectForVideo(els.video, now);
      if (result.faceLandmarks && result.faceLandmarks.length > 0) {
        quality = evaluateFrame(result.faceLandmarks[0]);
      } else {
        quality = { isDetected: false, isSized: false, isCentered: false, isFrontal: false, isReady: false };
      }
    } catch (e) {
      console.warn('detectForVideo failed:', e);
      quality = { isDetected: false, isSized: false, isCentered: false, isFrontal: false, isReady: false };
    }
    updateQualityUI(quality);

    if (quality.isReady) {
      stableFrames++;
      if (stableFrames >= 6 && !countdownInterval) {
        startCountdown();
      }
    } else {
      stableFrames = 0;
      cancelCountdown();
    }
  }
  requestAnimationFrame(detectLoop);
}

function evaluateFrame(landmarks) {
  let minX = 1, maxX = 0, minY = 1, maxY = 0;
  for (const lm of landmarks) {
    if (lm.x < minX) minX = lm.x;
    if (lm.x > maxX) maxX = lm.x;
    if (lm.y < minY) minY = lm.y;
    if (lm.y > maxY) maxY = lm.y;
  }
  const faceH = maxY - minY;
  const cx = (minX + maxX) / 2;
  const cy = (minY + maxY) / 2;

  // Symmetry: distance nose tip ↔ each outer eye corner
  const eyeOuterR = landmarks[33];
  const eyeOuterL = landmarks[263];
  const nose = landmarks[1];
  const distR = Math.hypot(eyeOuterR.x - nose.x, eyeOuterR.y - nose.y);
  const distL = Math.hypot(eyeOuterL.x - nose.x, eyeOuterL.y - nose.y);
  const symmetry = Math.min(distR, distL) / Math.max(distR, distL);

  const isSized = faceH > 0.34 && faceH < 0.72;
  const isCentered = Math.abs(cx - 0.5) < 0.09 && Math.abs(cy - 0.48) < 0.12;
  const isFrontal = symmetry > 0.86;

  return {
    isDetected: true,
    isSized, isCentered, isFrontal,
    isReady: isSized && isCentered && isFrontal,
    metrics: { faceH, cx, cy, symmetry }
  };
}

function updateQualityUI(q) {
  els.qDetected.classList.toggle('on', q.isDetected);
  els.qSized.classList.toggle('on', q.isSized);
  els.qCentered.classList.toggle('on', q.isCentered);
  els.qFrontal.classList.toggle('on', q.isFrontal);
  els.cameraFrame.classList.toggle('ready', q.isReady);

  // Contextual status text
  if (!q.isDetected) setCameraStatus('Place ton visage dans le cadre');
  else if (!q.isSized) setCameraStatus(q.metrics.faceH < 0.34 ? 'Approche-toi un peu' : 'Recule un peu');
  else if (!q.isCentered) setCameraStatus('Recentre ton visage');
  else if (!q.isFrontal) setCameraStatus('Regarde droit devant');
  else setCameraStatus('Parfait, reste immobile…');
}

function startCountdown() {
  if (countdownInterval) return;
  let n = 3;
  els.captureCountdown.hidden = false;
  els.countdownValue.textContent = n;
  countdownInterval = setInterval(() => {
    n--;
    if (n <= 0) {
      cancelCountdown();
      captureFromVideo();
    } else {
      els.countdownValue.textContent = n;
      // Re-trigger pulse animation
      els.captureCountdown.style.animation = 'none';
      void els.captureCountdown.offsetWidth;
      els.captureCountdown.style.animation = '';
    }
  }, 700);
}

function cancelCountdown() {
  if (countdownInterval) {
    clearInterval(countdownInterval);
    countdownInterval = null;
  }
  if (els.captureCountdown) els.captureCountdown.hidden = true;
}

async function saveToHistory(features, classification, confidence, calibration, exposure) {
  try {
    const { samplePoints, ...featuresClean } = features;
    const thumbnail = await generateThumbnail(els.preview);
    const entry = {
      id: Date.now().toString(),
      date: new Date().toISOString(),
      season: classification.season,
      features: featuresClean,
      classification,
      confidence,
      calibration,
      exposure,
      thumbnail
    };
    const savedId = await dbSave(entry);
    if (lastAnalysis && savedId) {
      lastAnalysis.savedId = savedId;
    }
  } catch (e) {
    console.warn('Save to history failed:', e);
  }
}

function captureFromVideo() {
  if (!els.video.videoWidth) return;
  detectLoopRunning = false;
  cancelCountdown();

  const tempCanvas = document.createElement('canvas');
  tempCanvas.width = els.video.videoWidth;
  tempCanvas.height = els.video.videoHeight;
  const tctx = tempCanvas.getContext('2d');
  tctx.drawImage(els.video, 0, 0);

  tempCanvas.toBlob((blob) => {
    if (!blob) {
      showError('Capture impossible. Réessaie.');
      return;
    }
    stopCamera();
    const file = new File([blob], 'capture.jpg', { type: 'image/jpeg' });
    analyze(file);
  }, 'image/jpeg', 0.92);
}

// ============================================================
// HISTORY UI
// ============================================================

let compareMode = false;
let selectedIds = new Set();

async function showHistory() {
  switchView('history');
  selectedIds.clear();
  compareMode = false;
  els.toggleCompare.classList.remove('on');
  els.toggleCompare.textContent = 'Mode comparaison';
  updateSelectInfo();
  await renderHistory();
}

async function renderHistory() {
  const entries = await dbGetAll();

  // Update lead with stats
  if (entries.length > 0) {
    const validated = entries.filter(e => e.userPick).length;
    const corrected = entries.filter(e => e.userPick && e.userPick.season !== e.classification?.season).length;
    const statsLead = document.getElementById('history-lead');
    if (statsLead) {
      statsLead.innerHTML = `${entries.length} analyse${entries.length > 1 ? 's' : ''} · ${validated} validée${validated > 1 ? 's' : ''} · ${corrected} corrigée${corrected > 1 ? 's' : ''}. Stockage local uniquement.`;
    }
  }

  if (entries.length === 0) {
    els.historyGrid.innerHTML = '';
    els.historyEmpty.style.display = 'block';
    els.historyClear.style.display = 'none';
    els.historyExport.style.display = 'none';
    els.toggleCompare.style.display = 'none';
    return;
  }

  els.historyEmpty.style.display = 'none';
  els.historyClear.style.display = '';
  els.historyExport.style.display = '';
  els.toggleCompare.style.display = entries.length >= 2 ? '' : 'none';

  els.historyGrid.innerHTML = entries.map(e => historyCardHTML(e)).join('');

  // Wire up clicks
  els.historyGrid.querySelectorAll('.history-card').forEach(card => {
    card.addEventListener('click', (ev) => {
      if (ev.target.closest('.history-card-actions')) return;
      const id = card.dataset.id;
      const entry = entries.find(x => x.id === id);
      if (!entry) return;
      if (compareMode) toggleSelect(id);
      else viewHistoryEntry(entry);
    });
  });

  els.historyGrid.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', (ev) => {
      ev.stopPropagation();
      const card = btn.closest('.history-card');
      const id = card.dataset.id;
      const entry = entries.find(x => x.id === id);
      if (entry) viewHistoryEntry(entry);
    });
  });

  els.historyGrid.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (ev) => {
      ev.stopPropagation();
      const card = btn.closest('.history-card');
      const id = card.dataset.id;
      if (confirm('Supprimer cette analyse ?')) {
        await dbDelete(id);
        selectedIds.delete(id);
        await renderHistory();
        updateSelectInfo();
      }
    });
  });
}

function historyCardHTML(entry) {
  const algoSeason = entry.season;
  const userSeason = entry.userPick?.season;
  const displaySeason = userSeason || algoSeason;
  const data = SEASONS[displaySeason];
  const seasonName = data ? `${data.rest} <em>${data.em}</em>` : displaySeason;
  const conf = entry.confidence ? `${entry.confidence.score}%` : '—';
  const date = formatDate(entry.date);
  const palette = data ? data.palette.slice(0, 8) : [];
  const isSelected = selectedIds.has(entry.id);
  const selectIndex = isSelected ? [...selectedIds].indexOf(entry.id) + 1 : null;
  const isDisabled = compareMode && !isSelected && selectedIds.size >= 2;

  // Validation status
  let validationBadge = '';
  if (userSeason) {
    if (userSeason === algoSeason) {
      validationBadge = '<div class="card-validation">✓ Validée</div>';
    } else {
      validationBadge = '<div class="card-validation diverged">✓ Corrigée</div>';
    }
  }

  return `
    <article class="history-card ${isSelected ? 'selected' : ''} ${isDisabled ? 'disabled' : ''}" data-id="${entry.id}">
      ${selectIndex ? `<div class="compare-badge">${selectIndex}</div>` : ''}
      ${validationBadge}
      <img class="history-thumb" src="${entry.thumbnail}" alt="">
      <div class="history-info">
        <div class="history-season">${seasonName}</div>
        <div class="history-meta">
          <span>${date}</span>
          <span>${conf}</span>
        </div>
        <div class="history-mini-palette">
          ${palette.map(([n, hex]) => `<span style="background:${hex}"></span>`).join('')}
        </div>
      </div>
      <div class="history-card-actions">
        <button class="view-btn" type="button">Voir</button>
        <button class="delete-btn" type="button">Supprimer</button>
      </div>
    </article>
  `;
}

function toggleSelect(id) {
  if (selectedIds.has(id)) {
    selectedIds.delete(id);
  } else if (selectedIds.size < 2) {
    selectedIds.add(id);
  }
  updateSelectInfo();
  renderHistory();
}

function updateSelectInfo() {
  const n = selectedIds.size;
  if (!compareMode) {
    els.selectInfo.textContent = 'Mode normal · clique pour voir';
    els.selectInfo.classList.remove('active');
    els.compareGo.hidden = true;
  } else if (n === 0) {
    els.selectInfo.textContent = 'Sélectionne deux analyses à comparer';
    els.selectInfo.classList.remove('active');
    els.compareGo.hidden = true;
  } else if (n === 1) {
    els.selectInfo.textContent = '1 sélectionnée · choisis-en une autre';
    els.selectInfo.classList.add('active');
    els.compareGo.hidden = true;
  } else {
    els.selectInfo.textContent = '2 analyses sélectionnées';
    els.selectInfo.classList.add('active');
    els.compareGo.hidden = false;
  }
}

function viewHistoryEntry(entry) {
  // Clear fresh analysis state — drape feature requires raw imageData not stored in history
  lastAnalysis = null;
  // Recreate a features object with empty samplePoints so showResult doesn't break
  const features = { ...entry.features, samplePoints: {} };
  const calibration = entry.calibration || { applied: false, scleraCount: 0 };
  // If the entry has a user-validated pick, show that as the main season,
  // with the algo's original pick available for divergence display.
  const algoSeason = entry.classification.season;
  const displaySeason = entry.userPick?.season || algoSeason;
  const displayClassif = { ...entry.classification, season: displaySeason };
  showResult(features, displayClassif, entry.confidence, calibration, algoSeason, entry.exposure || null);
}

async function showCompare() {
  if (selectedIds.size !== 2) return;
  const ids = [...selectedIds];
  const all = await dbGetAll();
  const e1 = all.find(x => x.id === ids[0]);
  const e2 = all.find(x => x.id === ids[1]);
  if (!e1 || !e2) return;

  els.compareGrid.innerHTML = compareColumnHTML(e1) + compareColumnHTML(e2);
  switchView('compare');
}

function compareColumnHTML(entry) {
  const data = SEASONS[entry.season];
  if (!data) return '<div class="compare-col">Données indisponibles</div>';

  const f = entry.features;
  const conf = entry.confidence ? `${entry.confidence.score}%` : '—';
  const rows = [
    ['ITA', `${f.ita.toFixed(1)}°`],
    ['L* peau', f.skin.L.toFixed(1)],
    ['a* peau', f.skin.a.toFixed(1)],
    ['b* peau', f.skin.b.toFixed(1)],
    ['C* peau', f.skinChroma.toFixed(1)],
    ['Hue peau', `${f.skinHue.toFixed(0)}°`]
  ];
  if (f.hair) rows.push(['L* cheveux', f.hair.L.toFixed(1)]);
  if (f.contrast !== undefined) rows.push(['Contraste', f.contrast.toFixed(1)]);

  return `
    <div class="compare-col">
      <img class="compare-thumb" src="${entry.thumbnail}" alt="">
      <div class="compare-season">${data.rest} <em>${data.em}</em></div>
      <div class="compare-meta">
        <span>${formatDate(entry.date)}</span>
        <span>Confiance ${conf}</span>
      </div>
      <div class="compare-data">
        ${rows.map(([k, v]) => `<div class="data-row"><span>${k}</span><span>${v}</span></div>`).join('')}
      </div>
      <div class="compare-palette-section">
        <div class="compare-palette-label">Palette · ${data.palette.length} couleurs</div>
        <div class="compare-palette">
          ${data.palette.map(([n, hex]) => `<div class="compare-swatch" style="background:${hex}" title="${n} ${hex}"></div>`).join('')}
        </div>
      </div>
    </div>
  `;
}

// ============================================================
// RECOMMENDATIONS VIEW
// ============================================================

function showRecommendations() {
  const season = currentSeason;
  if (!season || !SEASONS[season]) {
    showError("Pas de saison active pour les recommandations.");
    return;
  }
  switchView('reco');
  const data = SEASONS[season];
  els.recoSeasonName.innerHTML = `${data.rest} <em>${data.em}</em>`;
  els.recoGenderFilter.value = 'all';
  els.recoTypeFilter.value = 'all';
  els.recoPriceFilter.value = '';
  els.recoBrandFilter.value = 'all';
  updateModeBar();
  renderRecommendations();
}

function updateModeBar() {
  els.recoModeBar.className = 'reco-mode-bar mode-' + catalogMode;
  const statusText = els.recoModeStatus.querySelector('.reco-mode-text');

  if (catalogMode === 'demo') {
    statusText.textContent = 'Mode démo · catalogue synthétique généré localement';
    els.recoLoadReal.hidden = false;
    els.recoLoadReal.disabled = false;
    els.recoLoadReal.textContent = 'Charger des produits réels';
    els.recoLoadDemo.hidden = true;
    els.recoRefresh.hidden = true;
    els.recoBrandFilterGroup.hidden = true;
  } else if (catalogMode === 'loading') {
    statusText.innerHTML = 'Chargement des marques<span class="reco-loading-dots"></span>';
    els.recoLoadReal.hidden = false;
    els.recoLoadReal.disabled = true;
    els.recoLoadDemo.hidden = true;
    els.recoRefresh.hidden = true;
  } else if (catalogMode === 'real') {
    const brandCount = new Set(CATALOG.map(p => p.source_brand_id)).size;
    const okBrands = lastBrandResults?.filter(b => b.status === 'ok').length || brandCount;
    const totalBrands = lastBrandResults?.length || BRAND_SOURCES.length;
    statusText.textContent = `Catalogue réel · ${CATALOG.length} produits · ${okBrands}/${totalBrands} marques actives`;
    els.recoLoadReal.hidden = true;
    els.recoLoadDemo.hidden = false;
    els.recoRefresh.hidden = false;
    els.recoBrandFilterGroup.hidden = false;
    populateBrandFilter();
  } else if (catalogMode === 'error') {
    const failedCount = lastBrandResults?.filter(b => b.status === 'failed').length || 0;
    statusText.textContent = `Échec : ${failedCount}/${BRAND_SOURCES.length} marques ont échoué · mode démo réactivé`;
    els.recoLoadReal.hidden = false;
    els.recoLoadReal.disabled = false;
    els.recoLoadReal.textContent = 'Réessayer';
    els.recoLoadDemo.hidden = true;
    els.recoRefresh.hidden = true;
    els.recoBrandFilterGroup.hidden = true;
  }

  renderBrandStatus();
}

function renderBrandStatus() {
  if (!lastBrandResults || lastBrandResults.length === 0) {
    els.recoBrandStatus.hidden = true;
    return;
  }
  els.recoBrandStatus.hidden = false;

  const okCount = lastBrandResults.filter(b => b.status === 'ok').length;
  const failedCount = lastBrandResults.filter(b => b.status === 'failed').length;
  els.recoBrandSummary.textContent = `Statut des marques · ${okCount} succès · ${failedCount} échecs`;

  els.recoBrandList.innerHTML = lastBrandResults.map(b => {
    const cls = b.status === 'ok' ? 'ok' : 'failed';
    if (b.status === 'ok') {
      const via = b.via ? ` · ${b.via}` : '';
      return `<div class="reco-brand-item ${cls}" title="${b.endpoint || ''}${via}">
        <span>${b.name}</span>
        <span class="reco-brand-count">${b.count}${via}</span>
      </div>`;
    } else {
      const errorShort = (b.error || 'erreur inconnue').slice(0, 80);
      return `<div class="reco-brand-item ${cls}" title="${b.error?.replace(/"/g, '&quot;') || ''}">
        <span>${b.name}</span>
        <span class="reco-brand-count">CORS / 4xx</span>
      </div>`;
    }
  }).join('');
}

function populateBrandFilter() {
  const brands = [...new Set(CATALOG.map(p => p.source_brand || p.brand))].sort();
  els.recoBrandFilter.innerHTML = '<option value="all">Toutes</option>' +
    brands.map(b => `<option value="${b}">${b}</option>`).join('');
}

function renderRecommendations() {
  const season = currentSeason;
  if (!season) return;

  if (catalogMode === 'loading') {
    els.recoGrid.innerHTML = '<div class="reco-loading">Récupération des catalogues<span class="reco-loading-dots"></span></div>';
    els.recoEmpty.style.display = 'none';
    els.recoCount.textContent = '...';
    return;
  }

  const filters = {
    gender: els.recoGenderFilter.value,
    type: els.recoTypeFilter.value,
    maxPrice: els.recoPriceFilter.value ? parseInt(els.recoPriceFilter.value, 10) : null,
    brand: els.recoBrandFilter ? els.recoBrandFilter.value : 'all'
  };

  const products = recommendProducts(season, filters);

  els.recoCount.textContent = `${products.length} produit${products.length > 1 ? 's' : ''}`;

  if (products.length === 0) {
    els.recoGrid.innerHTML = '';
    els.recoEmpty.style.display = 'block';
    return;
  }

  els.recoEmpty.style.display = 'none';
  // Cap to top 60 to keep rendering snappy on large real catalogs
  els.recoGrid.innerHTML = products.slice(0, 60).map(p => recoCardHTML(p)).join('');

  // Attach image error fallback (some Shopify CDN URLs may 404 or block)
  els.recoGrid.querySelectorAll('.reco-image.has-photo').forEach(el => {
    const img = new Image();
    img.onload = () => { /* OK */ };
    img.onerror = () => {
      el.classList.remove('has-photo');
      el.style.backgroundImage = 'none';
    };
    if (el.dataset.imageUrl) img.src = el.dataset.imageUrl;
  });
}

function recoCardHTML(p) {
  const isDark = needsLightText(p.color_hex);
  const imageClass = isDark ? 'dark' : 'light';
  const matchHex = p.bestMatch ? p.bestMatch.hex : p.color_hex;
  const matchName = p.bestMatch ? p.bestMatch.name : p.color_name;
  const hasPhoto = p.is_real && p.image_url;

  const photoStyle = hasPhoto
    ? `background-image: url('${p.image_url}'); background-color: ${p.color_hex}`
    : `background: ${p.color_hex}`;

  const brandDisplay = p.source_brand || p.brand;
  const genderLabels = { men: 'Homme', women: 'Femme', unisex: 'Unisexe' };
  const genderLabel = genderLabels[p.gender] || '';
  const brandLine = genderLabel
    ? `${brandDisplay} · ${genderLabel}`
    : brandDisplay;

  return `
    <article class="reco-card" data-id="${p.id}">
      <div class="reco-image ${imageClass}${hasPhoto ? ' has-photo' : ''}"
           style="${photoStyle}"
           data-image-url="${hasPhoto ? p.image_url : ''}">
        ${hasPhoto ? `<span class="reco-color-chip" style="background:${p.color_hex}"></span>` : ''}
        <div class="reco-score-badge">${p.score}</div>
        <div class="reco-image-content">
          <div class="reco-image-type">${p.type_label}</div>
          <div class="reco-image-name">${p.color_name}</div>
        </div>
      </div>
      <div class="reco-info">
        <div class="reco-brand">${brandLine}</div>
        <div class="reco-name">${p.name}</div>
        <div class="reco-price">${p.price} ${p.currency === 'EUR' ? '€' : (p.currency === 'USD' ? '$' : p.currency)}</div>
        ${p.sizes && p.sizes.length ? `<div class="reco-sizes">${p.sizes.slice(0, 6).join(' · ')}</div>` : ''}
        <div class="reco-match">
          <span class="reco-match-swatch" style="background:${matchHex}"></span>
          <span>↔ ${matchName} (ΔE ${p.distance.toFixed(1)})</span>
        </div>
      </div>
      <a class="reco-link" href="${p.url}" target="_blank" rel="noopener">Voir le produit →</a>
    </article>
  `;
}

// ============================================================
// MIROIR VIVANT — real-time drape via camera
// ============================================================
// Pipeline per frame: video → work canvas (mirrored, ≤480px) → getImageData
// → ImageSegmenter (VIDEO mode) → fast luminance-modulated recolor of
// background/clothes/others → putImageData to display canvas.
// Segmentation runs every 2nd frame (mask reused between) to hold ~24-30 fps.
// Compositing avoids Lab per-pixel math: drape RGB is modulated by pixel luma
// so the texture (folds, shadows) survives. ~10x faster than the Lab path
// used in the static drape view, at slight fidelity cost — right tradeoff live.

let mirrorState = {
  running: false,
  stream: null,
  segmenter: null,
  rafId: null,
  frameCount: 0,
  lastMask: null,
  maskW: 0, maskH: 0,
  mode: 'single',              // 'single' | 'duel'
  drapeHex: null,              // single mode color
  duelLeftHex: null,           // duel: palette color (left)
  duelRightHex: null,          // duel: avoid color (right)
  fpsWindow: [],
};

let videoSegmenter = null;
async function initVideoSegmenter() {
  if (videoSegmenter) return videoSegmenter;
  const vision = await FilesetResolver.forVisionTasks(
    "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm"
  );
  videoSegmenter = await ImageSegmenter.createFromOptions(vision, {
    baseOptions: {
      modelAssetPath: "https://storage.googleapis.com/mediapipe-models/image_segmenter/selfie_multiclass_256x256/float32/latest/selfie_multiclass_256x256.tflite"
    },
    runningMode: "VIDEO",
    outputCategoryMask: true,
    outputConfidenceMasks: false
  });
  return videoSegmenter;
}

function hexToRgbFast(hex) {
  const n = parseInt(hex.slice(1), 16);
  return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
}

// Recolor non-person pixels. Luma-modulated so folds/shadows show through.
// side: 'all' | 'left' | 'right' (split at W/2 in *display* space; the work
// canvas is already mirrored so left = viewer's left).
function mirrorRecolor(imgData, mask, drapeRgb, W, side) {
  const d = imgData.data;
  const dl = (drapeRgb.r * 77 + drapeRgb.g * 150 + drapeRgb.b * 29) >> 8;
  const modBase = Math.max(46, dl);
  const half = W >> 1;
  for (let i = 0; i < mask.length; i++) {
    const cat = mask[i];
    if (cat === 1 || cat === 2 || cat === 3) continue; // keep hair + skin
    if (side !== 'all') {
      const x = i % W;
      if (side === 'left' && x >= half) continue;
      if (side === 'right' && x < half) continue;
    }
    const p = i * 4;
    const luma = (d[p] * 77 + d[p + 1] * 150 + d[p + 2] * 29) >> 8;
    let f = 0.55 + 0.45 * (luma / modBase);
    if (f > 1.5) f = 1.5;
    // Slight luma feed keeps texture visible on very dark drapes (black)
    const tex = luma * 0.10;
    let r = drapeRgb.r * f + tex, g = drapeRgb.g * f + tex, b = drapeRgb.b * f + tex;
    d[p]     = r > 255 ? 255 : r;
    d[p + 1] = g > 255 ? 255 : g;
    d[p + 2] = b > 255 ? 255 : b;
  }
}

async function startMirror() {
  const season = currentSeason;
  if (!season || !SEASONS[season]) {
    showError("Lance d'abord une analyse pour connaître ta palette.");
    return;
  }
  switchView('mirror');
  els.mirrorError.style.display = 'none';
  els.mirrorLoading.style.display = 'flex';

  const data = SEASONS[season];
  // Defaults: first palette color; duel = first palette vs first avoid
  mirrorState.drapeHex = mirrorState.drapeHex || data.palette[0][1];
  mirrorState.duelLeftHex = mirrorState.duelLeftHex || data.palette[0][1];
  mirrorState.duelRightHex = mirrorState.duelRightHex || (data.avoid[0] ? data.avoid[0][1] : '#808080');

  renderMirrorStrips();
  updateMirrorModeUI();

  try {
    const [stream] = await Promise.all([
      navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: cameraFacing }, width: { ideal: 640 }, height: { ideal: 480 } },
        audio: false
      }),
      initVideoSegmenter()
    ]);
    mirrorState.stream = stream;
    els.mirrorVideo.srcObject = stream;
    await els.mirrorVideo.play();

    // Work at reduced size for speed
    const vw = els.mirrorVideo.videoWidth || 640;
    const vh = els.mirrorVideo.videoHeight || 480;
    const scale = Math.min(1, 480 / vw);
    const W = Math.round(vw * scale), H = Math.round(vh * scale);
    els.mirrorCanvas.width = W;
    els.mirrorCanvas.height = H;
    mirrorState._work = document.createElement('canvas');
    mirrorState._work.width = W;
    mirrorState._work.height = H;

    mirrorState.running = true;
    mirrorState.frameCount = 0;
    mirrorState.lastMask = null;
    els.mirrorLoading.style.display = 'none';
    mirrorLoop();
  } catch (e) {
    console.error('Mirror start failed:', e);
    els.mirrorLoading.style.display = 'none';
    els.mirrorError.textContent = 'Caméra ou segmentation indisponible : ' + (e.message || e.name || 'erreur inconnue');
    els.mirrorError.style.display = 'block';
  }
}

function mirrorLoop() {
  if (!mirrorState.running) return;
  const t0 = performance.now();

  const W = els.mirrorCanvas.width, H = els.mirrorCanvas.height;
  const wctx = mirrorState._work.getContext('2d', { willReadFrequently: true });

  // Miroir horizontal seulement en selfie ; caméra arrière = image directe
  if (cameraFacing === 'user') {
    wctx.save();
    wctx.scale(-1, 1);
    wctx.drawImage(els.mirrorVideo, -W, 0, W, H);
    wctx.restore();
  } else {
    wctx.drawImage(els.mirrorVideo, 0, 0, W, H);
  }

  // Segment every 2nd frame; reuse mask otherwise
  if (mirrorState.frameCount % 2 === 0 || !mirrorState.lastMask) {
    try {
      const res = videoSegmenter.segmentForVideo(mirrorState._work, performance.now());
      if (res && res.categoryMask) {
        mirrorState.lastMask = res.categoryMask.getAsUint8Array().slice();
        mirrorState.maskW = res.categoryMask.width;
        res.close();
      }
    } catch (e) { /* keep previous mask */ }
  }
  mirrorState.frameCount++;

  const frame = wctx.getImageData(0, 0, W, H);

  if (mirrorState.lastMask && mirrorState.lastMask.length === W * H) {
    if (mirrorState.mode === 'single' && mirrorState.drapeHex) {
      mirrorRecolor(frame, mirrorState.lastMask, hexToRgbFast(mirrorState.drapeHex), W, 'all');
    } else if (mirrorState.mode === 'duel') {
      if (mirrorState.duelLeftHex)  mirrorRecolor(frame, mirrorState.lastMask, hexToRgbFast(mirrorState.duelLeftHex),  W, 'left');
      if (mirrorState.duelRightHex) mirrorRecolor(frame, mirrorState.lastMask, hexToRgbFast(mirrorState.duelRightHex), W, 'right');
    }
  }

  els.mirrorCanvas.getContext('2d').putImageData(frame, 0, 0);

  // FPS meter (rolling 30-frame window)
  const dt = performance.now() - t0;
  mirrorState.fpsWindow.push(dt);
  if (mirrorState.fpsWindow.length > 30) mirrorState.fpsWindow.shift();
  if (mirrorState.frameCount % 15 === 0) {
    const avg = mirrorState.fpsWindow.reduce((s, x) => s + x, 0) / mirrorState.fpsWindow.length;
    els.mirrorFps.textContent = `${Math.round(1000 / Math.max(avg, 16.7))} fps`;
  }

  mirrorState.rafId = requestAnimationFrame(mirrorLoop);
}

function stopMirror() {
  mirrorState.running = false;
  if (mirrorState.rafId) cancelAnimationFrame(mirrorState.rafId);
  if (mirrorState.stream) {
    mirrorState.stream.getTracks().forEach(t => t.stop());
    mirrorState.stream = null;
  }
  els.mirrorVideo.srcObject = null;
  mirrorState.lastMask = null;
  els.mirrorFps.textContent = '';
}

function renderMirrorStrips() {
  const data = SEASONS[currentSeason];
  if (!data) return;

  els.mirrorStripPalette.innerHTML = data.palette.map(([name, hex]) => {
    const sel = (mirrorState.mode === 'single' && hex === mirrorState.drapeHex) ||
                (mirrorState.mode === 'duel' && hex === mirrorState.duelLeftHex);
    return `<button class="mirror-chip${sel ? ' selected' : ''}" data-hex="${hex}" data-strip="palette"
      style="background:${hex}" title="${name}" type="button"></button>`;
  }).join('');

  // Références neutres en fin de bande palette
  els.mirrorStripPalette.innerHTML += '<span class="mirror-strip-divider"></span>' +
    NEUTRAL_REFS.map(([name, hex]) => {
      const sel = (mirrorState.mode === 'single' && hex === mirrorState.drapeHex) ||
                  (mirrorState.mode === 'duel' && hex === mirrorState.duelLeftHex);
      return `<button class="mirror-chip neutral${sel ? ' selected' : ''}" data-hex="${hex}" data-strip="palette"
        style="background:${hex}" title="${name} (référence neutre)" type="button"></button>`;
    }).join('');

  els.mirrorStripAvoid.innerHTML = data.avoid.map(([name, hex]) => {
    const sel = mirrorState.mode === 'duel' && hex === mirrorState.duelRightHex;
    return `<button class="mirror-chip${sel ? ' selected' : ''}" data-hex="${hex}" data-strip="avoid"
      style="background:${hex}" title="${name}" type="button"></button>`;
  }).join('');
}

function updateMirrorModeUI() {
  const duel = mirrorState.mode === 'duel';
  els.mirrorModeSingle.classList.toggle('active', !duel);
  els.mirrorModeDuel.classList.toggle('active', duel);
  els.mirrorSplitLine.hidden = !duel;
  els.mirrorBadges.hidden = !duel;
  els.mirrorStripAvoid.hidden = !duel;
  els.mirrorStripLabelAvoid.hidden = !duel;
  if (duel) updateMirrorBadges();
}

function findColorNameInSeason(hex) {
  const data = SEASONS[currentSeason];
  if (!data) return hex;
  const inPalette = data.palette.find(([, h]) => h === hex);
  if (inPalette) return inPalette[0];
  const inAvoid = data.avoid.find(([, h]) => h === hex);
  if (inAvoid) return inAvoid[0];
  return hex;
}

function updateMirrorBadges() {
  els.mirrorBadgeLeft.textContent = findColorNameInSeason(mirrorState.duelLeftHex);
  els.mirrorBadgeRight.textContent = findColorNameInSeason(mirrorState.duelRightHex);
}

// ============================================================
// AFFINAGE — poignet (sous-ton + veines) & iris gros plan
// ============================================================
// Le poignet interne est la peau la moins exposée au soleil : son b* reflète
// le sous-ton réel mieux qu'un visage hâlé. Les veines donnent le test
// catégoriel classique (bleu/violet = froid, vert = chaud). L'iris en gros
// plan remplace l'échantillon minuscule prélevé sur le portrait.
// Fusion : warmth' = 0.7×warmth_visage + 0.3×b*_poignet, ±4 selon veines ;
// iris HQ remplace features.iris puis re-fusion value/warmth existante.

async function fileToImageData(file, maxSide = 640) {
  const bmp = await createImageBitmap(file);
  const scale = Math.min(1, maxSide / Math.max(bmp.width, bmp.height));
  const W = Math.round(bmp.width * scale), H = Math.round(bmp.height * scale);
  const c = document.createElement('canvas');
  c.width = W; c.height = H;
  const ctx = c.getContext('2d', { willReadFrequently: true });
  ctx.drawImage(bmp, 0, 0, W, H);
  bmp.close();
  return { imageData: ctx.getImageData(0, 0, W, H), canvas: c, W, H };
}

function medianLab(labs) {
  const pick = (arr) => { const s = [...arr].sort((a, b) => a - b); return s[Math.floor(s.length / 2)]; };
  return { L: pick(labs.map(l => l.L)), a: pick(labs.map(l => l.a)), b: pick(labs.map(l => l.b)) };
}

async function analyzeWristPhoto(file) {
  const { imageData, W, H } = await fileToImageData(file, 600);
  const d = imageData.data;
  // Zone centrale 34% — évite bords, ombres de cadrage
  const x0 = Math.round(W * 0.33), x1 = Math.round(W * 0.67);
  const y0 = Math.round(H * 0.33), y1 = Math.round(H * 0.67);
  const labs = [];
  for (let y = y0; y < y1; y += 2) {
    for (let x = x0; x < x1; x += 2) {
      const p = (y * W + x) * 4;
      const lab = rgbToLab(d[p], d[p + 1], d[p + 2]);
      if (lab.L > 20 && lab.L < 92) labs.push(lab);
    }
  }
  if (labs.length < 200) throw new Error('Zone de peau insuffisante — recadre plein cadre sur le poignet.');
  const skin = medianLab(labs);

  // Veines : pixels nettement plus sombres que la peau médiane
  const veinPixels = labs.filter(l => l.L > skin.L - 16 && l.L < skin.L - 4);
  let veinsAuto = null;
  if (veinPixels.length >= 120) {
    let sx = 0, sy = 0;
    for (const l of veinPixels) {
      const h = Math.atan2(l.b - skin.b, l.a - skin.a); // teinte relative à la peau
      sx += Math.cos(h); sy += Math.sin(h);
    }
    let hue = Math.atan2(sy, sx) * 180 / Math.PI;
    if (hue < 0) hue += 360;
    if (hue >= 70 && hue <= 180) veinsAuto = 'warm';        // décalage vers le vert
    else if (hue >= 190 && hue <= 330) veinsAuto = 'cool';  // vers le bleu/violet
    else veinsAuto = 'mixed';
  }
  return { skin, veinsAuto, sampleCount: labs.length };
}

async function analyzeEyePhoto(file) {
  const { imageData, W, H } = await fileToImageData(file, 600);
  const d = imageData.data;
  const cx = W / 2, cy = H / 2, r = Math.min(W, H) * 0.18;
  const labs = [];
  for (let y = Math.round(cy - r); y < cy + r; y += 2) {
    for (let x = Math.round(cx - r); x < cx + r; x += 2) {
      if ((x - cx) ** 2 + (y - cy) ** 2 > r * r) continue;
      const p = (y * W + x) * 4;
      const lab = rgbToLab(d[p], d[p + 1], d[p + 2]);
      const C = Math.sqrt(lab.a ** 2 + lab.b ** 2);
      if (lab.L < 12) continue;                 // pupille
      if (lab.L > 88) continue;                 // reflet
      if (lab.L > 68 && C < 9) continue;        // sclère
      labs.push(lab);
    }
  }
  if (labs.length < 80) throw new Error("Iris non isolable — cadre l'œil plein cadre, au centre.");
  return { iris: medianLab(labs), sampleCount: labs.length };
}

function refineUpdateApplyState() {
  const ex = lastAnalysis?.extras;
  els.refineApply.disabled = !(ex && (ex.wrist || ex.eye));
}

async function applyRefinement() {
  if (!lastAnalysis) return;
  const ex = lastAnalysis.extras || {};
  const f = lastAnalysis.features;

  if (ex.eye) {
    f.iris = { ...ex.eye.iris };
    // Re-fusion value/warmth avec le nouvel iris (formules d'extractFeatures)
    const { skin, hair, iris } = f;
    if (hair && iris) {
      f.value  = skin.L * 0.55 + hair.L * 0.35 + iris.L * 0.10;
      f.warmth = skin.b * 0.50 + hair.b * 0.35 + iris.b * 0.15;
    } else if (iris) {
      f.value  = skin.L * 0.85 + iris.L * 0.15;
      f.warmth = skin.b * 0.80 + iris.b * 0.20;
    }
  }

  if (ex.wrist) {
    // Sous-ton poignet : pondère la température
    f.warmth = f.warmth * 0.7 + ex.wrist.skin.b * 0.3;
    const v = ex.wrist.veinsUser || ex.wrist.veinsAuto;
    if (v === 'cool') f.warmth -= 4;
    else if (v === 'warm') f.warmth += 4;
    f.wristUndertone = { b: ex.wrist.skin.b, veins: v };
  }

  const classification = classify(f);
  const confidence = computeConfidence(f, lastAnalysis.calibration, [], classification.ranked);
  lastAnalysis.classification = classification;
  lastAnalysis.confidence = confidence;

  // Persistance sur l'entrée d'historique existante
  if (lastAnalysis.savedId) {
    try {
      const all = await dbGetAll();
      const e = all.find(x => x.id === lastAnalysis.savedId);
      if (e) {
        const { samplePoints, ...featuresClean } = f;
        e.features = featuresClean;
        e.classification = classification;
        e.confidence = confidence;
        e.season = classification.season;
        e.extras = { wrist: ex.wrist ? { skinB: ex.wrist.skin.b, veins: ex.wrist.veinsUser || ex.wrist.veinsAuto } : null,
                     eye: ex.eye ? { iris: ex.eye.iris } : null };
        await dbSave(e);
      }
    } catch (err) { console.warn('Refine persist failed:', err); }
  }

  showResult(f, classification, confidence, lastAnalysis.calibration, null, lastAnalysis.exposure);
  switchView('result');
}

// ============================================================
// RÉFÉRENCES NEUTRES — règle colorimétrique vérifiée
// (fond blanc / blanc cassé / gris ; test blanc pur vs ivoire = température)
// ============================================================
const NEUTRAL_REFS = [
  ['Blanc pur', '#FFFFFF'],
  ['Ivoire', '#F5EEDC'],
  ['Gris neutre', '#B8B8B8'],
  ['Noir profond', '#0B0B0B']
];

async function renderNeutralDrape(name, hex) {
  if (!lastAnalysis) return;
  els.drapeLoading.hidden = false;
  await new Promise(r => setTimeout(r, 30));
  const composited = compositeWithDrape(
    lastAnalysis.imageData, lastAnalysis.segMask, lastAnalysis.landmarks, hexToRgb(hex)
  );
  els.drapeCanvas.width = composited.width;
  els.drapeCanvas.height = composited.height;
  els.drapeCanvas.getContext('2d').putImageData(composited, 0, 0);
  els.drapeCurrentName.innerHTML = `${name} <em>· référence neutre</em>`;
  els.drapeCurrentScore.textContent = name === 'Blanc pur' || name === 'Ivoire'
    ? 'Test de température : compare blanc pur ↔ ivoire'
    : 'Environnement neutre (standard pro)';
  els.drapeRankingList.querySelectorAll('li').forEach(li => li.classList.remove('current'));
  els.drapeSelector.querySelectorAll('.drape-swatch').forEach(sw => sw.classList.remove('active'));
  document.querySelectorAll('.drape-neutral-chip').forEach(c => c.classList.toggle('active', c.dataset.hex === hex));
  lastAnalysis._drapeShown = null; // non validable comme saison
  els.validationStatus.textContent = 'Référence neutre — observe, puis reviens aux saisons pour valider';
  els.drapeLoading.hidden = true;
}

// ============================================================
// ACCENT DYNAMIQUE — l'interface prend la couleur de TA saison
// ============================================================
const SEASON_ACCENT = {
  'light-spring': '#D98A5F', 'true-spring': '#C96F3B', 'bright-spring': '#E2543F',
  'light-summer': '#7C93B8', 'true-summer': '#5F7EA6', 'soft-summer': '#8A8FA3',
  'soft-autumn': '#A9825E', 'true-autumn': '#B26B36', 'deep-autumn': '#8A5230',
  'bright-winter': '#B03A5B', 'true-winter': '#3E5E8C', 'deep-winter': '#6E3448'
};

function mixWithWhite(hex, t) {
  const n = parseInt(hex.slice(1), 16);
  const r = Math.round(((n >> 16) & 255) * (1 - t) + 255 * t);
  const g = Math.round(((n >> 8) & 255) * (1 - t) + 255 * t);
  const b = Math.round((n & 255) * (1 - t) + 255 * t);
  return `rgb(${r},${g},${b})`;
}

function hexA(hex, alpha) {
  const n = parseInt(hex.slice(1), 16);
  return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${alpha})`;
}

// Thème saisonnier complet : accent + lavis d'ambiance + gradient de héros.
// Appliqué au <html> en inline (prioritaire sur :root et [data-theme]).
function setSeasonTheme(season) {
  try {
    const root = document.documentElement;
    const data = SEASONS[season];
    const hex = SEASON_ACCENT[season] || data?.palette?.[2]?.[1];
    if (!data || !hex) return;
    const dark = root.getAttribute('data-theme') === 'dark';
    root.style.setProperty('--accent', dark ? mixWithWhite(hex, 0.32) : hex);
    root.style.setProperty('--accent-2', mixWithWhite(hex, dark ? 0.18 : 0.15));
    const a = data.palette[0][1], b = data.palette[1]?.[1] || hex, c = data.palette[2]?.[1] || hex;
    root.style.setProperty('--wash-a', hexA(a, dark ? 0.12 : 0.18));
    root.style.setProperty('--wash-b', hexA(b, dark ? 0.09 : 0.13));
    root.style.setProperty('--hero-grad',
      `linear-gradient(135deg, ${hexA(a, dark ? 0.30 : 0.38)}, ${hexA(b, dark ? 0.20 : 0.26)} 55%, ${hexA(c, dark ? 0.14 : 0.18)})`);
    root.setAttribute('data-season', season);
  } catch (e) { console.warn('setSeasonTheme:', e); }
}

// Alias de compatibilité (anciens points d'appel)
function setDynamicAccent(season) { setSeasonTheme(season); }

// ============================================================
// ANALYTICS VIEW
// ============================================================

let lastProposedAnchors = null;

async function showAnalytics() {
  switchView('analytics');
  await renderAnalytics();
}

async function renderAnalytics() {
  const entries = await dbGetAll();
  const validatedEntries = entries.filter(e => e.userPick);
  const correctedEntries = validatedEntries.filter(e => e.userPick.season !== (e.classification?.season || e.season));

  // Summary
  if (entries.length === 0) {
    els.analyticsSummary.textContent = 'Aucune analyse enregistrée — lance des analyses puis valide-les pour alimenter cette vue.';
  } else if (validatedEntries.length === 0) {
    els.analyticsSummary.textContent = `${entries.length} analyse${entries.length > 1 ? 's' : ''} enregistrée${entries.length > 1 ? 's' : ''}, mais aucune validation utilisateur pour le moment. Lance des tests au drapé et valide une saison pour démarrer.`;
  } else {
    const acc = validatedEntries.length > 0 ? Math.round((validatedEntries.length - correctedEntries.length) / validatedEntries.length * 100) : 0;
    els.analyticsSummary.textContent = `${entries.length} analyse${entries.length > 1 ? 's' : ''} · ${validatedEntries.length} validée${validatedEntries.length > 1 ? 's' : ''} · ${correctedEntries.length} corrigée${correctedEntries.length > 1 ? 's' : ''} · accord algo/utilisateur : ${acc}%.`;
  }

  // Anchor status banner
  if (anchorsAreCustom) {
    els.anchorStatus.className = 'analytics-anchor-status custom';
    els.anchorStatus.textContent = '✓ Ancres personnalisées actives (basées sur tes validations)';
  } else {
    els.anchorStatus.className = 'analytics-anchor-status';
    els.anchorStatus.textContent = 'Ancres par défaut actives (théorie colorimétrique standard)';
  }

  // Confusion matrix
  renderConfusionMatrix(entries);

  // Recomputed anchors
  const proposed = recomputeAnchors(entries, 3);
  lastProposedAnchors = proposed;
  renderAnchorTable(proposed);

  // Apply button enabled only if at least one season was recomputed
  const recomputedCount = Object.values(proposed).filter(p => p.recomputed).length;
  els.applyAnchors.disabled = recomputedCount === 0;
  els.applyAnchors.textContent = recomputedCount === 0
    ? 'Pas assez de validations'
    : `Appliquer (${recomputedCount} saison${recomputedCount > 1 ? 's' : ''})`;
}

function renderConfusionMatrix(entries) {
  const { matrix, totalValidated } = buildConfusionMatrix(entries);
  const keys = Object.keys(SEASON_ANCHORS);

  // Find max for opacity scaling
  let maxVal = 1;
  for (const a of keys) {
    for (const u of keys) {
      if (matrix[a][u] > maxVal) maxVal = matrix[a][u];
    }
  }

  let html = '';
  // Top-left corner (empty)
  html += '<div class="matrix-cell header"></div>';
  // Header row: validation columns
  for (const u of keys) {
    html += `<div class="matrix-cell header" title="${SEASONS[u]?.name || u}">${SEASON_ABBR[u]}</div>`;
  }
  // Data rows
  for (const a of keys) {
    html += `<div class="matrix-cell header row-header" title="${SEASONS[a]?.name || a}">${SEASON_ABBR[a]}</div>`;
    for (const u of keys) {
      const v = matrix[a][u];
      const isDiag = a === u;
      const intensity = v / maxVal;
      const bg = v === 0 ? 'var(--surface)' :
                 isDiag ? `rgba(79, 124, 62, ${0.12 + 0.55 * intensity})` :
                 `rgba(184, 134, 11, ${0.12 + 0.55 * intensity})`;
      const cls = v === 0 ? 'empty' : (isDiag ? 'diagonal' : 'offdiag');
      html += `<div class="matrix-cell ${cls}" style="background:${bg}" title="Algo: ${a} → Validé: ${u} (${v})">${v || '·'}</div>`;
    }
  }
  els.matrixGrid.innerHTML = html;
}

function renderAnchorTable(proposed) {
  const keys = Object.keys(SEASON_ANCHORS);
  let html = '';
  html += '<div class="anchor-row header">';
  html += '<span>Saison</span><span>Défaut (T/V/C)</span><span>Proposée (T/V/C)</span><span>n</span>';
  html += '</div>';
  for (const season of keys) {
    const def = SEASON_ANCHORS[season];
    const prop = proposed[season];
    const data = SEASONS[season];
    const seasonName = data ? `${data.rest} ${data.em}` : season;
    const rowCls = prop.recomputed ? 'recomputed' : '';
    const defStr = `${def.temp.toFixed(2)} / ${def.value.toFixed(2)} / ${def.chroma.toFixed(2)}`;

    let propStr;
    if (prop.recomputed) {
      propStr = `${prop.temp.toFixed(2)} / ${prop.value.toFixed(2)} / ${prop.chroma.toFixed(2)}`;
      // Show delta
      const dT = prop.temp - def.temp;
      const dV = prop.value - def.value;
      const dC = prop.chroma - def.chroma;
      const sig = (n) => Math.abs(n) >= 0.15 ? '⚠' : '';
      const deltas = `${sig(dT)}${sig(dV)}${sig(dC)}`;
      if (deltas.trim()) propStr += ` <span class="delta">${deltas}</span>`;
    } else {
      propStr = `<span class="default-vals">— (${prop.samples} sample${prop.samples !== 1 ? 's' : ''})</span>`;
    }

    html += `
      <div class="anchor-row ${rowCls}">
        <span class="season-label">${seasonName}</span>
        <span class="default-vals">${defStr}</span>
        <span class="proposed-vals">${propStr}</span>
        <span class="sample-count">${prop.recomputed ? prop.samples : '—'}</span>
      </div>
    `;
  }
  els.anchorTable.innerHTML = html;
}

// ============================================================
// PRODUCT RECOMMENDATIONS — seed catalog + ΔE matching
// ============================================================

const PRODUCT_TYPES = [
  { key: 'top',       label: 'Tops',         templates: ['Chemise', 'T-shirt', 'Pull col rond', 'Blouse fluide', 'Cardigan léger'] },
  { key: 'bottom',    label: 'Bas',          templates: ['Pantalon droit', 'Jupe midi', 'Short en lin', 'Jean coupe haute'] },
  { key: 'dress',     label: 'Robes',        templates: ['Robe en lin', 'Robe d\'été', 'Robe portefeuille'] },
  { key: 'outer',     label: 'Manteaux',     templates: ['Veste oversize', 'Trench classique', 'Blazer structuré', 'Manteau long'] },
  { key: 'accessory', label: 'Accessoires',  templates: ['Foulard en soie', 'Ceinture en cuir', 'Sac bandoulière', 'Chapeau feutre'] }
];

const PRODUCT_BRANDS = ['Atelier Nord', 'Maison Veridis', 'Studio Linen', 'Fabrique Sud', 'Métier d\'Art', 'Lin & Co', 'L\'Étoffe', 'Verveine', 'Trame', 'Vestiaire 14'];
const PRODUCT_PRICES = [49, 65, 79, 95, 119, 145, 179, 215, 265];
const PRODUCT_SIZES = ['XS', 'S', 'M', 'L', 'XL'];

function generateCatalog() {
  const catalog = [];
  const genderCycle = ['women', 'men', 'unisex'];
  let id = 0;
  for (const [seasonKey, seasonData] of Object.entries(SEASONS)) {
    for (let i = 0; i < Math.min(4, seasonData.palette.length); i++) {
      const [colorName, hex] = seasonData.palette[i];
      id++;
      // Deterministic but varied selection
      const typeIdx = (id + i * 3) % PRODUCT_TYPES.length;
      const type = PRODUCT_TYPES[typeIdx];
      const tplIdx = ((id * 7) + i) % type.templates.length;
      const brandIdx = (id * 2 + i * 5) % PRODUCT_BRANDS.length;
      const priceIdx = (id * 3) % PRODUCT_PRICES.length;

      // Robes → femme, le reste cycle homme/femme/unisexe
      const gender = type.key === 'dress' ? 'women' : genderCycle[id % 3];

      catalog.push({
        id: `p${String(id).padStart(3, '0')}`,
        brand: PRODUCT_BRANDS[brandIdx],
        name: `${type.templates[tplIdx]} ${colorName.toLowerCase()}`,
        type: type.key,
        type_label: type.label,
        gender: gender,
        color_name: colorName,
        color_hex: hex,
        price: PRODUCT_PRICES[priceIdx],
        currency: 'EUR',
        sizes: PRODUCT_SIZES,
        url: `https://example.com/p/${id}`,
        season_origin: seasonKey
      });
    }
  }
  return catalog;
}

let CATALOG = generateCatalog();
let catalogMode = 'demo'; // 'demo' | 'loading' | 'real' | 'error'
let catalogError = null;
let lastBrandResults = null;

