// Build a flat lookup with normalized keys
const COLOR_LOOKUP = (() => {
  const lookup = {};
  for (const [name, hex] of Object.entries(COLOR_NAMES)) {
    lookup[name.toLowerCase().replace(/[-\s]/g, '')] = hex;
  }
  return lookup;
})();

function normalizeColorName(s) {
  return (s || '').toLowerCase().replace(/[-\s]/g, '').trim();
}

function findColorHex(rawName) {
  if (!rawName) return null;
  const cleaned = String(rawName).toLowerCase().trim();

  // 1. Direct match on normalized form
  const norm = normalizeColorName(cleaned);
  if (COLOR_LOOKUP[norm]) return COLOR_LOOKUP[norm];

  // 2. Substring match — try each color name as substring in input
  // Sort by length (longest first) so "navy blue" matches "navy" + "blue" → navy
  const sortedNames = Object.keys(COLOR_NAMES).sort((a, b) => b.length - a.length);
  for (const name of sortedNames) {
    if (cleaned.includes(name)) return COLOR_NAMES[name];
  }

  // 3. Word-level match
  const words = cleaned.split(/[\s,/-]+/).filter(Boolean);
  for (const word of words) {
    if (COLOR_NAMES[word]) return COLOR_NAMES[word];
  }

  return null;
}

// ============================================================
// FETCH REAL PRODUCTS
// ============================================================

async function fetchWithFallback(url, signal) {
  const errors = [];
  // Try direct first
  try {
    const r = await fetch(url, { signal, mode: 'cors' });
    if (r.ok) {
      const data = await r.json();
      return { data, via: 'direct' };
    }
    errors.push(`direct: HTTP ${r.status}`);
  } catch (e) {
    errors.push(`direct: ${e.message || 'CORS/network'}`);
  }
  // Try each proxy in sequence
  for (let i = 0; i < CORS_PROXIES.length; i++) {
    try {
      const r = await fetch(CORS_PROXIES[i](url), { signal });
      if (r.ok) {
        const data = await r.json();
        return { data, via: `proxy ${i + 1}` };
      }
      errors.push(`proxy ${i + 1}: HTTP ${r.status}`);
    } catch (e) {
      errors.push(`proxy ${i + 1}: ${e.message || 'failed'}`);
    }
  }
  const err = new Error(errors.join(' · '));
  err.attempts = errors;
  throw err;
}

// Try multiple URL variants for a brand. Some Shopify stores expose products.json
// only at certain paths, or use www/no-www inconsistently.
async function fetchBrandWithVariants(brand) {
  const base = brand.url.replace(/\/$/, '');
  const altBase = base.startsWith('https://www.')
    ? 'https://' + base.slice('https://www.'.length)
    : 'https://www.' + base.slice('https://'.length);

  const variants = [
    `${base}/products.json?limit=50`,
    `${base}/collections/all/products.json?limit=50`,
    `${altBase}/products.json?limit=50`
  ];

  const errors = [];
  for (const url of variants) {
    try {
      const { data, via } = await fetchWithFallback(url);
      if (data && Array.isArray(data.products) && data.products.length > 0) {
        return { data, url, via };
      }
      errors.push(`${url.replace(base, '').replace(altBase, '')}: empty`);
    } catch (e) {
      errors.push(`${url.replace(base, '').replace(altBase, '')}: ${e.message?.split(' · ')[0] || 'failed'}`);
    }
  }
  const err = new Error(`Toutes les variantes échouent. Détails : ${errors.join(' | ')}`);
  err.attempts = errors;
  throw err;
}

function findColorOption(product) {
  const options = product.options || [];
  return options.findIndex(o => /color|colour|couleur/i.test(o.name || ''));
}

function extractVariantColorName(variant, product, colorOptIdx) {
  if (colorOptIdx < 0) return null;
  // Shopify variants store option values as option1, option2, option3
  return variant[`option${colorOptIdx + 1}`] || null;
}

function classifyProductType(product) {
  const type = (product.product_type || '').toLowerCase();
  const title = (product.title || '').toLowerCase();
  const tags = Array.isArray(product.tags)
    ? product.tags.join(' ').toLowerCase()
    : String(product.tags || '').toLowerCase();
  const handle = (product.handle || '').toLowerCase();
  const all = `${type} ${title} ${tags} ${handle}`;

  if (/\b(shoe|sneaker|boot|sandal|flat|heel|pump|loafer|trainer|runner|chaussure|botte|basket)\b/.test(all)) return 'shoes';
  if (/\b(dress|robe|gown)\b/.test(all)) return 'dress';
  if (/\b(jacket|coat|blazer|cardigan|trench|parka|anorak|manteau|veste|gilet)\b/.test(all)) return 'outer';
  if (/\b(pant|trouser|jean|short|skirt|legging|culotte|pantalon|jupe|jogger)\b/.test(all)) return 'bottom';
  if (/\b(shirt|tee|t-shirt|top|blouse|sweater|sweatshirt|hoodie|pull|chemise|polo|tank|tunic)\b/.test(all)) return 'top';
  if (/\b(scarf|bag|hat|cap|belt|jewelry|watch|sock|glove|foulard|sac|chapeau|ceinture|chaussette)\b/.test(all)) return 'accessory';
  return 'top';
}

// Detect product gender from Shopify metadata + brand hints.
// Returns 'men' | 'women' | 'unisex' | 'unknown'.
function classifyProductGender(product, brand) {
  // Brand-level override: some brands only sell one gender
  if (brand?.gender_only) return brand.gender_only;

  const type = (product.product_type || '').toLowerCase();
  const title = (product.title || '').toLowerCase();
  const tags = Array.isArray(product.tags)
    ? product.tags.join(' ').toLowerCase()
    : String(product.tags || '').toLowerCase();
  const handle = (product.handle || '').toLowerCase();
  const all = `${type} ${title} ${tags} ${handle}`;

  // Explicit unisex markers first
  if (/\b(unisex|unisexe|gender[- ]?neutral|all[- ]?gender|all[- ]?genders)\b/.test(all)) return 'unisex';

  // 'womenswear' contains 'mens' as substring — handle explicitly
  const hasWomenswear = /\bwomenswear\b/.test(all);
  const mascMarkers = /\b(mens?|men's|male|homme|hommes|monsieur|gentleman|boys?|boy's)\b/;
  const femMarkers  = /\b(womens?|women's|female|femme|femmes|lady|ladies|girls?|girl's)\b/;

  const isMen   = mascMarkers.test(all) && !hasWomenswear;
  const isWomen = femMarkers.test(all) || hasWomenswear;

  if (isMen && !isWomen) return 'men';
  if (isWomen && !isMen) return 'women';
  if (isMen && isWomen) return 'unisex';

  // Heuristic fallback by category — only for items unambiguously gendered
  if (/\b(dress|robe|gown|skirt|jupe|bra|brassiere|culotte|tights|legging)\b/.test(all)) return 'women';
  if (/\b(boxer|brief|tie|cravate|necktie|tuxedo|smoking|suit\b)\b/.test(all)) return 'men';

  // Brand-level fallback if detection failed
  if (brand?.gender_default) return brand.gender_default;

  return 'unknown';
}

function extractSizes(product) {
  const sizeOption = (product.options || []).find(o => /size|taille/i.test(o.name || ''));
  if (!sizeOption || !Array.isArray(sizeOption.values)) return [];
  return sizeOption.values.slice(0, 8);
}

function pickBestVariant(product, colorOptIdx, colorName) {
  // Return first available variant for this color, or any with this color, or first overall
  const variants = product.variants || [];
  if (colorOptIdx >= 0 && colorName) {
    const matching = variants.filter(v =>
      v[`option${colorOptIdx + 1}`] === colorName
    );
    const available = matching.find(v => v.available);
    if (available) return available;
    if (matching.length) return matching[0];
  }
  return variants.find(v => v.available) || variants[0] || null;
}

async function parseBrandProducts(brand, raw) {
  if (!raw || !Array.isArray(raw.products)) return [];
  const out = [];

  for (const product of raw.products) {
    if (!product.variants || product.variants.length === 0) continue;
    if (!product.images || product.images.length === 0) continue;

    const colorOptIdx = findColorOption(product);
    const type = classifyProductType(product);
    const gender = classifyProductGender(product, brand);
    const sizes = extractSizes(product);

    // Collect unique colors across variants
    const seenColors = new Set();
    const variantColorNames = colorOptIdx >= 0
      ? product.variants.map(v => v[`option${colorOptIdx + 1}`]).filter(Boolean)
      : [null];

    const uniqueColors = [...new Set(variantColorNames)];
    if (uniqueColors.length === 0) uniqueColors.push(null);

    for (const colorName of uniqueColors) {
      const hex = findColorHex(colorName) || findColorHex(product.title);
      if (!hex) continue;

      const key = `${product.id}-${colorName || 'default'}`;
      if (seenColors.has(key)) continue;
      seenColors.add(key);

      const variant = pickBestVariant(product, colorOptIdx, colorName);
      if (!variant) continue;

      const price = parseFloat(variant.price);
      if (!isFinite(price) || price <= 0) continue;

      // Try to find variant-specific image, fallback to first product image
      let imageUrl = product.images[0]?.src;
      if (variant.featured_image?.src) {
        imageUrl = variant.featured_image.src;
      } else if (variant.image_id && product.images) {
        const variantImage = product.images.find(img => img.id === variant.image_id);
        if (variantImage) imageUrl = variantImage.src;
      }
      // Shopify CDN supports on-the-fly resizing — 480px wide is plenty for cards
      // and cuts payload ~10x vs raw 2000px+ originals.
      if (imageUrl && /cdn\.shopify\.com/.test(imageUrl)) {
        imageUrl += (imageUrl.includes('?') ? '&' : '?') + 'width=480';
      }

      out.push({
        id: `${brand.id}-${product.id}-${variant.id}`,
        brand: product.vendor || brand.name,
        source_brand: brand.name,
        source_brand_id: brand.id,
        source_region: brand.region,
        name: product.title,
        type: type,
        type_label: PRODUCT_TYPES.find(t => t.key === type)?.label || type,
        gender: gender,
        color_name: colorName || 'Standard',
        color_hex: hex,
        price: Math.round(price),
        currency: 'USD',
        sizes: sizes,
        image_url: imageUrl,
        url: `${brand.url}/products/${product.handle}`,
        available: variant.available,
        is_real: true
      });
    }
  }
  return out;
}

async function fetchRealCatalog(forceRefresh = false) {
  // Check cache first (24h TTL)
  if (!forceRefresh) {
    const cached = await dbGetConfig('product_cache');
    if (cached && cached.timestamp && (Date.now() - cached.timestamp < 24 * 3600 * 1000)) {
      return { products: cached.products, brands: cached.brands, fromCache: true };
    }
  }

  const brandResults = [];
  const allProducts = [];

  // Fetch in parallel but track each brand's status
  const promises = BRAND_SOURCES.map(async brand => {
    try {
      const { data, url, via } = await fetchBrandWithVariants(brand);
      const products = await parseBrandProducts(brand, data);
      brandResults.push({
        ...brand,
        status: 'ok',
        count: products.length,
        via: via,
        endpoint: url
      });
      return products;
    } catch (e) {
      brandResults.push({
        ...brand,
        status: 'failed',
        count: 0,
        error: e.message || 'unknown error',
        attempts: e.attempts || []
      });
      return [];
    }
  });

  const results = await Promise.all(promises);
  for (const r of results) allProducts.push(...r);

  // Preserve original brand order in results array
  brandResults.sort((a, b) => {
    const aIdx = BRAND_SOURCES.findIndex(s => s.id === a.id);
    const bIdx = BRAND_SOURCES.findIndex(s => s.id === b.id);
    return aIdx - bIdx;
  });

  if (allProducts.length === 0) {
    const err = new Error('Aucun produit récupéré depuis les marques sélectionnées.');
    err.brandResults = brandResults;
    throw err;
  }

  // Cache
  await dbSetConfig('product_cache', {
    timestamp: Date.now(),
    products: allProducts,
    brands: brandResults
  });

  return { products: allProducts, brands: brandResults, fromCache: false };
}

async function activateRealCatalog(forceRefresh = false) {
  catalogMode = 'loading';
  catalogError = null;
  try {
    const result = await fetchRealCatalog(forceRefresh);
    CATALOG = result.products;
    lastBrandResults = result.brands;
    catalogMode = 'real';
    return result;
  } catch (e) {
    catalogError = e.message;
    catalogMode = 'error';
    lastBrandResults = e.brandResults || null;
    // Restore demo catalog so UI isn't empty
    CATALOG = generateCatalog();
    throw e;
  }
}

function activateDemoCatalog() {
  CATALOG = generateCatalog();
  catalogMode = 'demo';
  catalogError = null;
  lastBrandResults = null;
}

// ============================================================
// PRODUCT MATCHING
// ============================================================

function deltaE(lab1, lab2) {
  // CIE76 — simple and fast, sufficient for product matching
  const dL = lab1.L - lab2.L;
  const da = lab1.a - lab2.a;
  const db = lab1.b - lab2.b;
  return Math.sqrt(dL * dL + da * da + db * db);
}

function recommendProducts(seasonKey, filters = {}) {
  const seasonData = SEASONS[seasonKey];
  if (!seasonData) return [];

  // Precompute Lab for each palette color
  const paletteLabs = seasonData.palette.map(([n, hex]) => {
    const rgb = hexToRgb(hex);
    return { name: n, hex, lab: rgbToLab(rgb.r, rgb.g, rgb.b) };
  });

  let products = CATALOG.slice();
  if (filters.type && filters.type !== 'all') {
    products = products.filter(p => p.type === filters.type);
  }
  if (filters.maxPrice) {
    products = products.filter(p => p.price <= filters.maxPrice);
  }
  if (filters.brand && filters.brand !== 'all') {
    products = products.filter(p => (p.source_brand || p.brand) === filters.brand);
  }
  if (filters.gender && filters.gender !== 'all') {
    products = products.filter(p => {
      const g = p.gender || 'unknown';
      // 'unisex' filter: strictly unisex only
      if (filters.gender === 'unisex') return g === 'unisex';
      // 'men' / 'women' filters: that gender OR explicitly unisex.
      // 'unknown' is excluded so filter visibly reduces results.
      return g === filters.gender || g === 'unisex';
    });
  }

  // Score each product by closest palette color
  const scored = products.map(p => {
    const rgb = hexToRgb(p.color_hex);
    const productLab = rgbToLab(rgb.r, rgb.g, rgb.b);
    let bestDist = Infinity;
    let bestColor = null;
    for (const c of paletteLabs) {
      const dE = deltaE(productLab, c.lab);
      if (dE < bestDist) {
        bestDist = dE;
        bestColor = c;
      }
    }
    const score = Math.max(0, Math.min(100, Math.round(100 - bestDist * 2)));
    return {
      ...p,
      bestMatch: bestColor,
      distance: bestDist,
      score: score
    };
  });

  // Keep only products meaningfully close to the palette
  return scored
    .filter(p => p.distance < 40)
    .sort((a, b) => a.distance - b.distance);
}

function needsLightText(hex) {
  const rgb = hexToRgb(hex);
  // Perceptual brightness (ITU-R BT.601 weights)
  const brightness = (rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000;
  return brightness < 130;
}

// ============================================================
// EXPORT TRAINING DATA
// ============================================================

async function exportTrainingData() {
  const entries = await dbGetAll();
  if (entries.length === 0) {
    alert('Aucune analyse à exporter.');
    return;
  }

  const data = entries.map(e => {
    const algoSeason = e.classification?.season || e.season;
    const userSeason = e.userPick?.season || null;
    return {
      id: e.id,
      date: e.date,
      algo_season: algoSeason,
      user_validated_season: userSeason,
      user_validated_at: e.userPick?.date || null,
      user_corrected: userSeason !== null && userSeason !== algoSeason,
      confidence_score: e.confidence?.score ?? null,
      confidence_label: e.confidence?.label ?? null,
      confidence_penalties: e.confidence?.penalties ?? [],
      calibration: {
        applied: e.calibration?.applied ?? false,
        sclera_count: e.calibration?.scleraCount ?? 0
      },
      features: e.features  // no thumbnail, no imageData — only numeric features
    };
  });

  const corrected = data.filter(d => d.user_corrected).length;
  const validated = data.filter(d => d.user_validated_season !== null).length;

  const payload = {
    exported_at: new Date().toISOString(),
    version: 'palette-mvp-v0.8',
    counts: {
      total: data.length,
      user_validated: validated,
      user_corrected: corrected,
      unvalidated: data.length - validated
    },
    entries: data
  };

  const json = JSON.stringify(payload, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `palette-training-${new Date().toISOString().slice(0, 10)}.json`;
  a.click();
  URL.revokeObjectURL(url);
}

// ============================================================
// DRAPE VIEW
// ============================================================

function showDrape() {
  if (!lastAnalysis) {
    showError("Pas d'analyse récente — relance une analyse pour utiliser le test au drapé.");
    return;
  }
  switchView('drape');
  setupDrapeView();
}

function setupDrapeView() {
  const ranked = rankSeasons(lastAnalysis.features);

  // Build full ranking list
  els.drapeRankingList.innerHTML = ranked.map(r => {
    const data = SEASONS[r.season];
    if (!data) return '';
    return `
      <li data-season="${r.season}">
        <span></span>
        <span class="drape-ranking-name">${data.rest} ${data.em}</span>
        <span class="drape-ranking-score">${r.score}</span>
      </li>
    `;
  }).join('');

  // Selector swatches, ordered by ranking
  els.drapeSelector.innerHTML = ranked.map(r => {
    const data = SEASONS[r.season];
    if (!data) return '';
    return `
      <div class="drape-swatch" data-season="${r.season}" title="${data.rest} ${data.em} · score ${r.score}">
        <div class="drape-swatch-inner" style="background:${data.palette[0][1]}"></div>
      </div>
    `;
  }).join('');

  // Références neutres (règle pro : fond blanc/gris ; test blanc↔ivoire)
  let neutralRow = document.getElementById('drape-neutral-row');
  if (!neutralRow) {
    neutralRow = document.createElement('div');
    neutralRow.className = 'drape-neutral-row';
    neutralRow.id = 'drape-neutral-row';
    els.drapeSelector.parentElement.appendChild(neutralRow);
  }
  neutralRow.innerHTML = '<span class="drape-neutral-tag">Références neutres</span>' +
    NEUTRAL_REFS.map(([n, h]) =>
      `<button class="drape-neutral-chip" data-hex="${h}" title="${n}" type="button" style="background:${h}"></button>`
    ).join('');
  neutralRow.querySelectorAll('.drape-neutral-chip').forEach(chip => {
    const ref = NEUTRAL_REFS.find(([, h]) => h === chip.dataset.hex);
    chip.addEventListener('click', () => renderNeutralDrape(ref[0], ref[1]));
  });

  // Wire clicks
  els.drapeRankingList.querySelectorAll('li').forEach(li => {
    li.addEventListener('click', () => renderDrape(li.dataset.season));
  });
  els.drapeSelector.querySelectorAll('.drape-swatch').forEach(sw => {
    sw.addEventListener('click', () => renderDrape(sw.dataset.season));
  });

  // Render: start with user's previously validated season if any, else the algo pick
  const initialSeason = lastAnalysis.userPick?.season || lastAnalysis.classification.season;
  renderDrape(initialSeason);
}

async function renderDrape(season) {
  if (!lastAnalysis) return;
  const data = SEASONS[season];
  if (!data) return;

  els.drapeLoading.hidden = false;
  // Yield to browser so loading indicator paints
  await new Promise(r => setTimeout(r, 30));

  const drapeRgb = hexToRgb(data.palette[0][1]);
  const composited = compositeWithDrape(
    lastAnalysis.imageData,
    lastAnalysis.segMask,
    lastAnalysis.landmarks,
    drapeRgb
  );

  els.drapeCanvas.width = composited.width;
  els.drapeCanvas.height = composited.height;
  els.drapeCanvas.getContext('2d').putImageData(composited, 0, 0);

  // Update labels
  const ranked = rankSeasons(lastAnalysis.features);
  const scored = ranked.find(r => r.season === season);
  els.drapeCurrentName.innerHTML = `${data.rest} <em>${data.em}</em>`;
  els.drapeCurrentScore.textContent = scored ? `Harmonie ${scored.score}/100` : '—';

  // Highlight current
  els.drapeRankingList.querySelectorAll('li').forEach(li => {
    li.classList.toggle('current', li.dataset.season === season);
  });
  els.drapeSelector.querySelectorAll('.drape-swatch').forEach(sw => {
    sw.classList.toggle('active', sw.dataset.season === season);
  });

  // Track currently shown drape for validation
  lastAnalysis._drapeShown = season;

  updateValidationBanner();

  els.drapeLoading.hidden = true;
}

function updateValidationBanner() {
  if (!lastAnalysis) return;
  const shown = lastAnalysis._drapeShown;
  const picked = lastAnalysis.userPick?.season;
  const algoPick = lastAnalysis.classification.season;
  if (!shown) return;

  const data = SEASONS[shown];
  if (!data) return;

  if (picked === shown) {
    // Currently showing the season the user validated
    els.validationStatus.textContent = '✓ Saison validée';
    els.validationStatus.className = 'validation-status validated';
    els.validateBtn.textContent = 'Choix confirmé';
    els.validateBtn.disabled = true;
  } else {
    // Showing a different season — invite to validate it
    const algoLabel = shown === algoPick ? ' (choix de l\'algo)' : '';
    els.validationStatus.textContent = `Affiché : ${data.rest} ${data.em}${algoLabel}`;
    els.validationStatus.className = 'validation-status';
    els.validateBtn.textContent = picked ? 'Changer mon choix' : 'Valider ce drapé';
    els.validateBtn.disabled = false;
  }
}

async function validateUserPick(season) {
  if (!lastAnalysis) return;
  lastAnalysis.userPick = {
    season: season,
    date: new Date().toISOString()
  };
  // Persist to IDB if entry was saved
  if (lastAnalysis.savedId) {
    await updateEntryUserPick(lastAnalysis.savedId, lastAnalysis.userPick);
  }
  updateValidationBanner();
}

async function updateEntryUserPick(entryId, userPick) {
  try {
    const all = await dbGetAll();
    const entry = all.find(e => e.id === entryId);
    if (!entry) return false;
    entry.userPick = userPick;
    await dbSave(entry);
    return true;
  } catch (e) {
    console.warn('updateEntryUserPick failed:', e);
    return false;
  }
}

