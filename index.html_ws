// ============================================================
// INDEXEDDB — local history of analyses
// ============================================================

const DB_NAME = 'palette-db';
const DB_STORE = 'analyses';
const DB_VERSION = 1;

let dbPromise = null;

function openDB() {
  if (dbPromise) return dbPromise;
  dbPromise = new Promise((resolve, reject) => {
    if (!window.indexedDB) {
      return reject(new Error('IndexedDB indisponible'));
    }
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = (e) => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(DB_STORE)) {
        const store = db.createObjectStore(DB_STORE, { keyPath: 'id' });
        store.createIndex('date', 'date');
      }
    };
    req.onsuccess = (e) => resolve(e.target.result);
    req.onerror = (e) => reject(e.target.error);
  });
  return dbPromise;
}

async function dbSave(entry) {
  try {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(DB_STORE, 'readwrite');
      const req = tx.objectStore(DB_STORE).put(entry);
      req.onsuccess = () => resolve(entry.id);
      req.onerror = (e) => reject(e.target.error);
    });
  } catch (e) {
    console.warn('dbSave failed:', e);
    return null;
  }
}

async function dbGetAll() {
  try {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(DB_STORE, 'readonly');
      const req = tx.objectStore(DB_STORE).getAll();
      req.onsuccess = () => {
        const all = (req.result || []).filter(e => !String(e.id).startsWith('config__'));
        all.sort((a, b) => b.date.localeCompare(a.date));
        resolve(all);
      };
      req.onerror = (e) => reject(e.target.error);
    });
  } catch (e) {
    console.warn('dbGetAll failed:', e);
    return [];
  }
}

async function dbGetConfig(key) {
  try {
    const db = await openDB();
    return new Promise((resolve) => {
      const tx = db.transaction(DB_STORE, 'readonly');
      const req = tx.objectStore(DB_STORE).get('config__' + key);
      req.onsuccess = () => resolve(req.result?.value ?? null);
      req.onerror = () => resolve(null);
    });
  } catch (e) {
    return null;
  }
}

async function dbSetConfig(key, value) {
  try {
    const db = await openDB();
    return new Promise((resolve) => {
      const tx = db.transaction(DB_STORE, 'readwrite');
      const req = tx.objectStore(DB_STORE).put({
        id: 'config__' + key,
        date: new Date().toISOString(),
        value: value
      });
      req.onsuccess = () => resolve(true);
      req.onerror = () => resolve(false);
    });
  } catch (e) {
    return false;
  }
}

async function dbDeleteConfig(key) {
  try {
    const db = await openDB();
    return new Promise((resolve) => {
      const tx = db.transaction(DB_STORE, 'readwrite');
      const req = tx.objectStore(DB_STORE).delete('config__' + key);
      req.onsuccess = () => resolve(true);
      req.onerror = () => resolve(false);
    });
  } catch (e) {
    return false;
  }
}

async function dbDelete(id) {
  try {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(DB_STORE, 'readwrite');
      const req = tx.objectStore(DB_STORE).delete(id);
      req.onsuccess = () => resolve();
      req.onerror = (e) => reject(e.target.error);
    });
  } catch (e) {
    console.warn('dbDelete failed:', e);
  }
}

async function dbClear() {
  try {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(DB_STORE, 'readwrite');
      const req = tx.objectStore(DB_STORE).clear();
      req.onsuccess = () => resolve();
      req.onerror = (e) => reject(e.target.error);
    });
  } catch (e) {
    console.warn('dbClear failed:', e);
  }
}

async function generateThumbnail(sourceCanvas, maxDim = 600) {
  const scale = Math.min(1, maxDim / Math.max(sourceCanvas.width, sourceCanvas.height));
  const w = Math.round(sourceCanvas.width * scale);
  const h = Math.round(sourceCanvas.height * scale);

  // Try createImageBitmap with high-quality resampling (best path)
  try {
    const bitmap = await createImageBitmap(sourceCanvas, {
      resizeWidth: w,
      resizeHeight: h,
      resizeQuality: 'high'
    });
    const tc = document.createElement('canvas');
    tc.width = w;
    tc.height = h;
    const ctx = tc.getContext('2d');
    ctx.drawImage(bitmap, 0, 0);
    bitmap.close();
    return tc.toDataURL('image/jpeg', 0.92);
  } catch (e) {
    // Fallback: two-pass downscale with high-quality smoothing
    const tc = document.createElement('canvas');
    tc.width = w;
    tc.height = h;
    const ctx = tc.getContext('2d');
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
    ctx.drawImage(sourceCanvas, 0, 0, w, h);
    return tc.toDataURL('image/jpeg', 0.92);
  }
}

function formatDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
}

