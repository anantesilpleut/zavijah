});

els.validateBtn.addEventListener('click', async () => {
  if (!lastAnalysis || !lastAnalysis._drapeShown) return;
  await validateUserPick(lastAnalysis._drapeShown);
});

els.export.addEventListener('click', () => {
  // Compose a downloadable palette image
  const data = SEASONS[currentSeason];
  if (!data) return;
  const c = document.createElement('canvas');
  c.width = 800; c.height = 1100;
  const x = c.getContext('2d');
  x.fillStyle = '#F4EEE3';
  x.fillRect(0, 0, c.width, c.height);
  x.fillStyle = '#1A1714';
  x.font = '300 56px Fraunces, serif';
  x.fillText(`${data.rest}`, 60, 100);
  x.fillStyle = '#6B2737';
  x.font = 'italic 300 56px Fraunces, serif';
  x.fillText(data.em, 60, 160);
  // Swatches
  const cols = 4, rows = 3, w = 160, h = 200, gap = 24;
  const startX = 60, startY = 240;
  data.palette.slice(0, 12).forEach((p, i) => {
    const col = i % cols, row = Math.floor(i / cols);
    const px = startX + col * (w + gap);
    const py = startY + row * (h + gap);
    x.fillStyle = p[1];
    x.fillRect(px, py, w, h - 40);
    x.fillStyle = '#1A1714';
    x.font = '400 11px JetBrains Mono, monospace';
    x.fillText(p[0].toUpperCase(), px, py + h - 22);
    x.fillStyle = '#8C8175';
    x.fillText(p[1].toUpperCase(), px, py + h - 8);
  });
  x.fillStyle = '#8C8175';
  x.font = '400 11px JetBrains Mono, monospace';
  x.fillText('PALETTE° — ANALYSE COLORIMÉTRIQUE PERSONNELLE', 60, 1050);
  const link = document.createElement('a');
  link.download = `palette-${data.rest.toLowerCase()}-${data.em.toLowerCase()}.png`;
  link.href = c.toDataURL('image/png');
  link.click();
});

// === Startup: load custom anchors if any ===
loadCustomAnchorsAtStartup();

// === Theme management ===
async function loadThemePreference() {
  let theme = await dbGetConfig('theme');
  if (!theme) {
    theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }
  document.documentElement.setAttribute('data-theme', theme);
  updateThemeIcon(theme);
}

function updateThemeIcon(theme) {
  const btn = document.getElementById('theme-toggle');
  if (!btn) return;
  btn.textContent = theme === 'dark' ? '☀' : '◐';
  btn.setAttribute('aria-label', theme === 'dark' ? 'Passer en thème clair' : 'Passer en thème sombre');
}

document.getElementById('theme-toggle')?.addEventListener('click', async () => {
  const current = document.documentElement.getAttribute('data-theme') || 'light';
  const next = current === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  updateThemeIcon(next);
  await dbSetConfig('theme', next);
  const s = currentSeason || await dbGetConfig('accent_season');
  if (s) setDynamicAccent(s);
});

loadThemePreference().then(async () => {
  const s = await dbGetConfig('accent_season');
  if (s) { setDynamicAccent(s); }
});

// === Season previews on landing ===
function renderSeasonPreviews() {
  const showcase = ['light-spring', 'deep-winter', 'soft-autumn', 'true-spring'];
  const container = document.getElementById('preview-cards');
  if (!container) return;
  container.innerHTML = showcase.map(key => {
    const data = SEASONS[key];
    if (!data) return '';
    const swatches = data.palette.slice(0, 6);
    return `
      <div class="preview-card">
        <div class="preview-swatches">
          ${swatches.map(([name, hex]) => `<span style="background:${hex}" title="${name}"></span>`).join('')}
        </div>
        <div class="preview-name">${data.rest} <em>${data.em}</em></div>
      </div>
    `;
  }).join('');
}
renderSeasonPreviews();

// === Analyses récentes sur l'accueil (Season Cards miniatures) ===
let _recentEntries = [];
async function renderRecentStrip() {
  const wrap = document.getElementById('recent-wrap');
  const strip = document.getElementById('recent-strip');
  if (!wrap || !strip) return;
  try {
    const all = await dbGetAll();
    _recentEntries = all.slice(0, 6);
    if (_recentEntries.length === 0) { wrap.hidden = true; return; }
    wrap.hidden = false;
    strip.innerHTML = _recentEntries.map((e, i) => {
      const data = SEASONS[e.userPick?.season || e.season];
      const pal = data ? data.palette.slice(0, 4) : [];
      const grad = pal.length
        ? `linear-gradient(135deg, ${pal.map(([, h], j) => hexA(h, 0.55 - j * 0.08)).join(',')})`
        : 'var(--bg-2)';
      const name = data ? `${data.rest} ${data.em}` : '—';
      const d = new Date(e.date);
      return `<button class="recent-card" data-idx="${i}" type="button" style="background:${grad}">
        ${e.thumbnail ? `<img src="${e.thumbnail}" alt="">` : ''}
        <span class="recent-card-name">${name}</span>
        <span class="recent-card-date">${d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}</span>
      </button>`;
    }).join('');
    strip.querySelectorAll('.recent-card').forEach(card => {
      card.addEventListener('click', () => {
        const e = _recentEntries[parseInt(card.dataset.idx, 10)];
        if (e && typeof viewHistoryEntry === 'function') viewHistoryEntry(e);
        else showHistory();
      });
    });
  } catch (err) { wrap.hidden = true; }
}
renderRecentStrip();

// === PWA: register service worker if deployed alongside (no-op in single-file usage) ===
if ('serviceWorker' in navigator && location.protocol === 'https:') {
  navigator.serviceWorker.register('sw.js').catch(() => { /* single-file mode: sw.js absent, fine */ });
}
</script>
</body>
</html>
