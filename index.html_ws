// Chip selection via delegation on both strips
function onMirrorChipClick(e) {
  const chip = e.target.closest('.mirror-chip');
  if (!chip) return;
  const hex = chip.dataset.hex;
  const strip = chip.dataset.strip;
  if (mirrorState.mode === 'single') {
    if (strip === 'palette') mirrorState.drapeHex = hex;
  } else {
    if (strip === 'palette') mirrorState.duelLeftHex = hex;
    else mirrorState.duelRightHex = hex;
    updateMirrorBadges();
  }
  renderMirrorStrips();
}
